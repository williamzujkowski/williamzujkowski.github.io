eleventyNavigation:
  key: Blog
  order: 3
---
<h1>Blog</h1>

<ul class="post-list">
  {%- for post in collections.posts | reverse -%}
    <li class="post-item">
      <h2 class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      <time class="post-date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
      <div class="post-excerpt">
        <p>{{ post.data.description or post.templateContent | striptags | truncate(200) }}</p>
      </div>
      <a href="{{ post.url }}" class="read-more">Read more &rarr;</a>
    </li>
  {%- endfor -%}
</ul>