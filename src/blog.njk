---
layout: base.njk
title: Blog
pagination:
  data: collections.posts
  size: 6
  alias: posts
permalink: "/blog/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}"
eleventyNavigation:
  key: Blog
  order: 3
---

{% breadcrumbs page %}
<div
  class="relative mb-8 bg-gray-light border border-border rounded-github overflow-hidden"
>
  <div class="flex flex-col md:flex-row items-center p-8 gap-6">
    <div class="flex-1 text-center md:text-left">
      <h1
        class="text-white text-3xl md:text-4xl font-bold mb-3 bg-gradient-to-r from-theme-accent to-accent bg-clip-text text-transparent"
      >
        Blog Posts
      </h1>
      <p class="text-text-secondary max-w-xl">
        Thoughts, insights, and explorations in technology, software development, and
        innovation. Filter by post type below to view regular content or vulnerability analyses.
      </p>

      <div class="flex flex-wrap gap-3 mt-6 justify-center md:justify-start">
        <div
          class="flex items-center bg-surface px-3 py-1.5 rounded-full border border-border"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            width="16"
            height="16"
            fill="currentColor"
            class="text-theme-accent mr-2"
          >
            <path
              d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 011-1h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"
            ></path>
          </svg>
          <span class="text-white text-sm">{{ collections.posts.length }} Total Posts</span>
        </div>

        <div
          class="flex items-center bg-surface px-3 py-1.5 rounded-full border border-border"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            width="16"
            height="16"
            fill="currentColor"
            class="text-theme-accent mr-2"
          >
            <path
              d="M8 16a2 2 0 001.985-1.75c.017-.137-.097-.25-.235-.25h-3.5c-.138 0-.252.113-.235.25A2 2 0 008 16z M8 1.5A3.5 3.5 0 004.5 5v2.947c0 .346-.102.683-.294.97l-1.703 2.556a.018.018 0 00-.003.01l.001.006c0 .002.002.004.004.006a.017.017 0 00.006.004l.007.001h10.964l.007-.001a.016.016 0 00.006-.004.016.016 0 00.004-.006l.001-.007a.017.017 0 00-.003-.01l-1.703-2.554a1.75 1.75 0 01-.294-.97V5A3.5 3.5 0 008 1.5"
            ></path>
          </svg>
          <span class="text-white text-sm">{{ (collections.posts | filterVulnerabilityPosts).length }} Vulnerability Reports</span>
        </div>

        <div
          class="flex items-center bg-surface px-3 py-1.5 rounded-full border border-border"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            width="16"
            height="16"
            fill="currentColor"
            class="text-theme-accent mr-2"
          >
            <path
              d="M15.5 3.54v4.815a.5.5 0 01-.792.41L12.624 7.33v1.945a.5.5 0 01-.792.41L9.749 8.25C9.603 10.425 7.741 12 5.5 12c-2.314 0-4.21-1.91-4.238-4.25a.5.5 0 01.137-.352.5.5 0 01.345-.147h.006c.163 0 .332.037.487.112a.5.5 0 01.237.334c.063.175.13.338.218.485.09.15.198.29.334.41.135.12.292.215.466.28.173.064.363.096.569.096.54 0 1.022-.235 1.352-.61.331-.375.522-.889.522-1.446 0-.157-.03-.317-.088-.465a1.78 1.78 0 00-.24-.396 1.7 1.7 0 00-.361-.318 1.568 1.568 0 00-.45-.214 1.58 1.58 0 00-1.022.076 1.678 1.678 0 00-.783.783 1.579 1.579 0 00-.147.548.502.502 0 01-.219.396c-.14.1-.325.13-.503.08a.484.484 0 01-.294-.258A4.087 4.087 0 012 6c0-1.74.9-3.33 2.33-4.19a4.05 4.05 0 014.622.7l2.066-1.23a.5.5 0 01.792.41v1.945l2.083-1.235a.5.5 0 01.607.095.5.5 0 01.11.504c-.02.06-.03.124-.03.186z"
            ></path>
          </svg>
          <span class="text-white text-sm">{{ (collections.posts | filterOutVulnerabilityPosts).length }} Blog Articles</span>
        </div>

        <div
          class="flex items-center bg-surface px-3 py-1.5 rounded-full border border-border"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            width="16"
            height="16"
            fill="currentColor"
            class="text-theme-accent mr-2"
          >
            <path
              d="M4.75 0a.75.75 0 01.75.75V2h5V.75a.75.75 0 011.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0113.25 16H2.75A1.75 1.75 0 011 14.25V3.75C1 2.784 1.784 2 2.75 2H4V.75A.75.75 0 014.75 0zm0 3.5h8.5a.25.25 0 01.25.25V6h-9V3.75a.25.25 0 01.25-.25zm-2 3h10.5v7.75a.25.25 0 01-.25.25H2.75a.25.25 0 01-.25-.25V6.5z"
            ></path>
          </svg>
          <span class="text-white text-sm"
            >Last updated: {{ ((collections.posts | filterOutVulnerabilityPosts | sort(true, false, "date")) | first).date | readableDate }}</span
          >
        </div>

        <div
          class="flex items-center bg-surface px-3 py-1.5 rounded-full border border-border"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            width="16"
            height="16"
            fill="currentColor"
            class="text-theme-accent mr-2"
          >
            <path
              d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0z"
            ></path>
            <path d="M8 9.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path>
          </svg>
          <span class="text-white text-sm"
            >{{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span
          >
        </div>
      </div>
    </div>

    <div class="w-full md:w-auto flex-shrink-0">
      <div class="relative w-full max-w-xs mx-auto">
        <svg
          viewBox="0 0 24 24"
          class="w-32 h-32 md:w-40 md:h-40 text-theme-accent mx-auto opacity-90"
        >
          <path
            fill="currentColor"
            d="M19.97 6.43L12 2L4.03 6.43L9.1 9.24C9.83 8.48 10.86 8 12 8C13.14 8 14.17 8.48 14.9 9.24L19.97 6.43M10 12C10 10.9 10.9 10 12 10C13.1 10 14 10.9 14 12C14 13.1 13.1 14 12 14C10.9 14 10 13.1 10 12M11 21.44L3 17V8.14L8.13 10.99C8.04 11.31 8 11.65 8 12C8 13.86 9.27 15.43 11 15.87V21.44M13 21.44V15.87C14.73 15.43 16 13.86 16 12C16 11.65 15.96 11.31 15.87 10.99L21 8.14V17L13 21.44Z"
          />
        </svg>

        <div
          class="w-24 h-24 md:w-32 md:h-32 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 rounded-full bg-surface/30 backdrop-blur-sm -z-10"
        ></div>
      </div>
    </div>
  </div>
</div>

<div class="tags-filter mb-8">
  <div class="gh-filter-header">
    <div class="gh-filter-title">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        width="16"
        height="16"
        fill="currentColor"
      >
        <path
          d="M15 2.5H1a.5.5 0 0 0-.4.8l5.8 6.8v5.6c0 .2.1.3.3.4h2.6c.2 0 .3-.2.3-.4V10l5.8-6.8a.5.5 0 0 0-.4-.8Z"
        ></path>
      </svg>
      <span>Filter by topics</span>
    </div>

    <div class="gh-search-container">
      <input
        type="text"
        id="search-input"
        placeholder="Search posts..."
        class="gh-search-input"
        aria-label="Search posts"
      />
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 16 16"
        class="gh-search-icon"
        fill="currentColor"
      >
        <path
          d="M11.5 7a4.499 4.499 0 11-8.998 0A4.499 4.499 0 0111.5 7zm-.82 4.74a6 6 0 111.06-1.06l3.04 3.04a.75.75 0 11-1.06 1.06l-3.04-3.04z"
        ></path>
      </svg>
    </div>

    <button class="gh-filter-clear" id="clear-filters">Clear filters (<span id="search-results-count">{{ (collections.posts | filterOutVulnerabilityPosts).length }}</span>)</button>
  </div>
  <div class="gh-tag-buttons">
    <button class="tag-btn selected" data-tag="">All Topics</button>
    <button class="tag-btn" data-tag="blog">Blog Articles</button>
    <button class="tag-btn" data-tag="vulnerability">Vulnerability Reports</button>
    <button class="tag-btn" data-tag="security">Security</button>
    <button class="tag-btn" data-tag="ai">AI</button>
    <button class="tag-btn" data-tag="cloud">Cloud</button>
    <button class="tag-btn" data-tag="llm">LLM</button>
    <button class="tag-btn" data-tag="programming">Programming</button>
  </div>
</div>

<div
  id="no-results-message"
  class="hidden max-w-md mx-auto text-center bg-gray-light p-8 rounded-github border border-border"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="48"
    height="48"
    fill="currentColor"
    viewBox="0 0 16 16"
    class="text-text-secondary mx-auto mb-4 opacity-70"
  >
    <path
      d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zM7 6.5C7 7.328 6.552 8 6 8s-1-.672-1-1.5S5.448 5 6 5s1 .672 1 1.5zm-2.715 5.933a.5.5 0 0 1-.183-.683A4.498 4.498 0 0 1 8 9.5a4.5 4.5 0 0 1 3.898 2.25.5.5 0 0 1-.866.5A3.498 3.498 0 0 0 8 10.5a3.498 3.498 0 0 0-3.032 1.75.5.5 0 0 1-.683.183zM10 8c-.552 0-1-.672-1-1.5S9.448 5 10 5s1 .672 1 1.5S10.552 8 10 8z"
    />
  </svg>
  <p class="text-white text-lg font-medium mb-2">No posts found</p>
  <p class="text-text-secondary mb-6">
    No posts matching your search criteria were found. Try different keywords or clear
    the search.
  </p>
  <button id="reset-search" class="gh-btn">Reset Search</button>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
  {%- for post in posts -%}
  <div
    class="gh-post-card searchable h-full"
    data-tags="{{ post.data.tags | join(',') | lower }}{% if post.fileSlug and post.fileSlug.includes('vulnerability-analysis') %},vulnerability{% else %},blog{% endif %}"
  >
    <!-- Post image with consistent ratio -->
    <div class="gh-post-image">
      {% if blogImage %} {% set blogImg = blogImage(post) %}
      <img
        src="/assets/images/{{ blogImg.path }}"
        alt="{{ blogImg.alt }}"
        class="w-full h-full object-cover"
      />
      {% else %}
      <img
        src="/assets/images/github-style/blog-placeholder.jpg"
        alt="Blog post illustration"
        class="w-full h-full object-cover"
      />
      {% endif %} {% if post.data.tags %}
      <div class="gh-post-tags-overlay">
        {% for tag in post.data.tags %} {% if tag != "posts" %}
        <span class="gh-badge">{{ tag }}</span>
        {% endif %} {% endfor %}
      </div>
      {% endif %}
    </div>

    <!-- Post content -->
    <div class="gh-post-content">
      <a href="{{ post.url | url }}" class="gh-post-title">{{ post.data.title }}</a>

      <div class="gh-post-meta">
        <div class="gh-post-date">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            width="14"
            height="14"
            fill="currentColor"
          >
            <path
              d="M4.75 0a.75.75 0 01.75.75V2h5V.75a.75.75 0 011.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0113.25 16H2.75A1.75 1.75 0 011 14.25V3.75C1 2.784 1.784 2 2.75 2H4V.75A.75.75 0 014.75 0zm0 3.5h8.5a.25.25 0 01.25.25V6h-9V3.75a.25.25 0 01.25-.25zm-2 3h10.5v7.75a.25.25 0 01-.25.25H2.75a.25.25 0 01-.25-.25V6.5z"
            ></path>
          </svg>
          <span>{{ post.data.date | readableDate }}</span>
        </div>

        {% set wordCount = post.templateContent | striptags | wordcount %}
        <div class="gh-post-reading-time" title="{{ wordCount }} words">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            width="14"
            height="14"
            fill="currentColor"
          >
            <path
              d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0zm9.28-1.72a.75.75 0 00-1.06-1.06L6.25 8.69l-.97-.97a.75.75 0 00-1.06 1.06l1.5 1.5a.75.75 0 001.06 0l3-3z"
            ></path>
          </svg>
          {% set readingTime = (wordCount / 200) | round %} {% if readingTime < 1 %}{%
          set readingTime = 1 %}{% endif %}
          <span>{{ readingTime }} min read</span>
        </div>
      </div>

      <div class="gh-post-excerpt">
        {% if post.data.description %} {{ post.data.description }} {% elif
        post.templateContent %} {{ post.templateContent | striptags | truncate(160) }}
        {% endif %}
      </div>

      <div class="gh-post-footer">
        <a href="{{ post.url | url }}" class="gh-read-more">
          Read article
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            width="16"
            height="16"
            fill="currentColor"
          >
            <path
              d="M8.22 2.97a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06l2.97-2.97H3.75a.75.75 0 010-1.5h7.44L8.22 4.03a.75.75 0 010-1.06z"
            ></path>
          </svg>
        </a>

        <!-- Additional tags for desktop/tablet view -->
        <div class="hidden sm:flex flex-wrap gap-1.5">
          {% for tag in post.data.tags %} {% if tag != "posts" and loop.index <= 2 %}
          <span class="text-xs py-1 px-2 bg-surface rounded-full text-text-secondary"
            >{{ tag }}</span
          >
          {% endif %} {% endfor %} {% if post.data.tags and (post.data.tags | length -
          1) > 2 %}
          <span class="text-xs py-1 px-2 bg-surface rounded-full text-text-secondary"
            >+{{ post.data.tags | length - 3 }}</span
          >
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  {%- endfor -%}
</div>

{% if pagination.pages.length > 1 %}
<div class="gh-pagination-container">
  <div class="gh-pagination-header">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 16 16"
      width="16"
      height="16"
      fill="currentColor"
    >
      <path
        d="M9.28 7.47l3.97-3.97a.75.75 0 0 1 1.06 0l.72.72a.75.75 0 0 1 0 1.06l-3.97 3.97 3.97 3.97a.75.75 0 0 1 0 1.06l-.72.72a.75.75 0 0 1-1.06 0L9.28 11.03 5.31 15a.75.75 0 0 1-1.06 0l-.72-.72a.75.75 0 0 1 0-1.06l3.97-3.97L3.53 5.28a.75.75 0 0 1 0-1.06l.72-.72a.75.75 0 0 1 1.06 0l3.97 3.97z"
      ></path>
    </svg>
    <span>Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
  </div>

  <nav aria-label="Blog pagination" class="gh-pagination">
    <div class="gh-pagination-nav">
      {% if pagination.href.previous %}
      <a
        href="{{ pagination.href.previous }}"
        class="gh-page-button gh-prev-button"
        aria-label="Previous page"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16"
          width="16"
          height="16"
          fill="currentColor"
        >
          <path
            d="M7.78 12.53a.75.75 0 01-1.06 0L2.47 8.28a.75.75 0 010-1.06l4.25-4.25a.75.75 0 011.06 1.06L4.81 7h7.44a.75.75 0 010 1.5H4.81l2.97 2.97a.75.75 0 010 1.06z"
          ></path>
        </svg>
        Previous
      </a>
      {% else %}
      <span class="gh-page-button gh-prev-button disabled">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16"
          width="16"
          height="16"
          fill="currentColor"
        >
          <path
            d="M7.78 12.53a.75.75 0 01-1.06 0L2.47 8.28a.75.75 0 010-1.06l4.25-4.25a.75.75 0 011.06 1.06L4.81 7h7.44a.75.75 0 010 1.5H4.81l2.97 2.97a.75.75 0 010 1.06z"
          ></path>
        </svg>
        Previous
      </span>
      {% endif %}

      <div class="gh-pagination-pages">
        {% for pageUrl in pagination.hrefs %} {% set pageNumber = loop.index %}
        <a
          href="{{ pageUrl }}"
          class="gh-page-number {% if page.url == pageUrl %}active{% endif %}"
          {% if page.url == pageUrl %}aria-current="page"{% endif %}
        >
          {{ pageNumber }}
        </a>
        {% endfor %}
      </div>

      {% if pagination.href.next %}
      <a
        href="{{ pagination.href.next }}"
        class="gh-page-button gh-next-button"
        aria-label="Next page"
      >
        Next
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16"
          width="16"
          height="16"
          fill="currentColor"
        >
          <path
            d="M8.22 2.97a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06l2.97-2.97H3.75a.75.75 0 010-1.5h7.44L8.22 4.03a.75.75 0 010-1.06z"
          ></path>
        </svg>
      </a>
      {% else %}
      <span class="gh-page-button gh-next-button disabled">
        Next
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16"
          width="16"
          height="16"
          fill="currentColor"
        >
          <path
            d="M8.22 2.97a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06l2.97-2.97H3.75a.75.75 0 010-1.5h7.44L8.22 4.03a.75.75 0 010-1.06z"
          ></path>
        </svg>
      </span>
      {% endif %}
    </div>
  </nav>
</div>
{% endif %}

<!-- Load the blog search and filtering functionality -->
<script src="/js/blog-search.js"></script>
