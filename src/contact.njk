---
layout: base.njk
title: Contact
permalink: /contact/
eleventyNavigation:
  key: Contact
  order: 4
---
{% breadcrumbs page %}
<div class="relative mb-8 rounded-github overflow-hidden">
  {% image "blog/tech-header.jpg", "Technology background", "100vw", [800, 1200, 1600] %}
  <div class="absolute inset-0 flex items-center justify-center bg-black/30">
    <h1 class="text-white text-2xl font-bold flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="24" height="24" fill="currentColor" class="mr-2"><path d="M1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0114.25 14H1.75A1.75 1.75 0 010 12.25v-8.5C0 2.784.784 2 1.75 2zM1.5 12.251c0 .138.112.25.25.25h12.5a.25.25 0 00.25-.25V5.809L8.38 9.397a.75.75 0 01-.76 0L1.5 5.809v6.442zm13-8.181v-.32a.25.25 0 00-.25-.25H1.75a.25.25 0 00-.25.25v.32L8 7.88l6.5-3.81z"></path></svg>
      Contact
    </h1>
  </div>
</div>

<p class="text-text-secondary mb-6">Get in touch with me through any of these channels or the contact form below.</p>

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <div class="p-6 border border-border rounded-github bg-surface">
    <h3 class="text-lg font-medium mb-4">Connect With Me</h3>
    
    <div class="flex flex-col gap-3">
      {% for social in site.social_media %}
        {% if social.enabled %}
          <a href="{{ social.url }}" class="flex items-center gap-3 p-2 rounded-github hover:bg-background transition-colors duration-200">
            {{ social.icon | safe }}
            <span>{{ social.name }}</span>
          </a>
        {% endif %}
      {% endfor %}
      
      <a href="mailto:{{ site.email }}" class="flex items-center gap-3 p-2 rounded-github hover:bg-background transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
          <path d="M1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0114.25 14H1.75A1.75 1.75 0 010 12.25v-8.5C0 2.784.784 2 1.75 2zM1.5 12.251c0 .138.112.25.25.25h12.5a.25.25 0 00.25-.25V5.809L8.38 9.397a.75.75 0 01-.76 0L1.5 5.809v6.442zm13-8.181v-.32a.25.25 0 00-.25-.25H1.75a.25.25 0 00-.25.25v.32L8 7.88l6.5-3.81z"></path>
        </svg>
        <span>{{ site.email }}</span>
      </a>
    </div>
  </div>

  <div class="p-6 border border-border rounded-github bg-surface">
    <h3 class="text-lg font-medium mb-4">Send a Message</h3>
    <form id="contact-form" action="https://formspree.io/f/your-formspree-id" method="POST" class="space-y-4">
      <div>
        <label for="name" class="block text-sm font-medium mb-1">Name</label>
        <input type="text" id="name" name="name" required
          class="w-full p-2 border border-border rounded-github bg-surface text-text focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30" 
          placeholder="Your name">
      </div>
      
      <div>
        <label for="email" class="block text-sm font-medium mb-1">Email</label>
        <input type="email" id="email" name="email" required 
          class="w-full p-2 border border-border rounded-github bg-surface text-text focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30" 
          placeholder="your.email@example.com">
      </div>
      
      <div>
        <label for="subject" class="block text-sm font-medium mb-1">Subject</label>
        <input type="text" id="subject" name="subject" required
          class="w-full p-2 border border-border rounded-github bg-surface text-text focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30" 
          placeholder="Message subject">
      </div>
      
      <div>
        <label for="message" class="block text-sm font-medium mb-1">Message</label>
        <textarea id="message" name="message" rows="5" required
          class="w-full p-2 border border-border rounded-github bg-surface text-text focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30" 
          placeholder="Your message..."></textarea>
      </div>
      
      <button type="submit" class="gh-btn gh-btn-primary mt-2 px-4 py-2 flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="mr-2">
          <path d="M10.894 2.553a1 1 0 00-1.41-1.41L3 7.625V6a1 1 0 10-2 0v3.5a1 1 0 001 1h3.5a1 1 0 100-2H4.335l7.97-7.95z"></path>
        </svg>
        Send Message
      </button>
    </form>

    <div id="form-success" class="hidden py-8 text-center">
      <div class="bg-primary/10 text-primary rounded-full w-12 h-12 flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="24" height="24" fill="currentColor">
          <path d="M13.78 4.22a.75.75 0 00-1.06 0L6.5 10.44 3.28 7.22a.75.75 0 00-1.06 1.06l3.75 3.75a.75.75 0 001.06 0l6.75-6.75a.75.75 0 000-1.06z"></path>
        </svg>
      </div>
      <h4 class="text-lg font-medium mb-2">Message Sent Successfully!</h4>
      <p class="text-text-secondary">Thank you for reaching out. I'll get back to you within 48 hours.</p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const formSuccess = document.getElementById('form-success');
    
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Add loading state
        const submitButton = form.querySelector('button[type="submit"]');
        const originalButtonText = submitButton.innerHTML;
        submitButton.disabled = true;
        submitButton.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="animate-spin mr-2">
            <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/>
            <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/>
          </svg>
          Sending...
        `;
        
        try {
          // For demo purposes only, we'll simulate a successful submission
          // In production, uncomment the fetch code below
          
          // const formData = new FormData(form);
          // const response = await fetch(form.action, {
          //   method: 'POST',
          //   body: formData,
          //   headers: {
          //     'Accept': 'application/json'
          //   }
          // });
          
          // Simulate network delay
          await new Promise(resolve => setTimeout(resolve, 1500));
          
          // Show success message
          form.classList.add('hidden');
          formSuccess.classList.remove('hidden');
        } catch (error) {
          console.error('Error submitting form:', error);
          submitButton.innerHTML = originalButtonText;
          submitButton.disabled = false;
          alert('There was a problem sending your message. Please try again or contact me directly via email.');
        }
      });
    }
  });
</script>