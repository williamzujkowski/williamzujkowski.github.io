---
layout: base.njk
title: Home
permalink: /
eleventyNavigation:
  key: Home
  order: 1
---
<div class="main-content">
  <header class="page-header">
    <h1 class="page-title">{{ site.title }}</h1>
    <p class="page-subtitle">{{ site.homepage.welcome_subtitle }}</p>
  </header>
  
  <div class="home-sections">
    <div class="about-section">
      <h2>About Me</h2>
      <p class="about-bio">I'm a software engineer specializing in cloud architecture, cybersecurity, and AI/ML applications. With experience across the full development lifecycle, I build robust, scalable solutions that solve complex problems.</p>
      
      <h3>Skills & Expertise</h3>
      <ul class="skills-list">
        {% for skill in site.homepage.skills %}
          <li class="skill-item">{{ skill }}</li>
        {% endfor %}
      </ul>
      
      <div class="interests-section">
        <h3>Interests</h3>
        <p>{{ site.homepage.interests }}</p>
      </div>
    </div>
    
    <div class="content-sidebar">
      <div class="connect-section">
        <h3>Connect With Me</h3>
        <div class="social-links">
          {% for social in site.social_media %}
            {% if social.enabled %}
              <a href="{{ social.url }}" class="social-link" target="_blank" aria-label="{{ social.name }}">
                {{ social.icon | safe }}
                <span>{{ social.name }}</span>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      
      {% if site.homepage.show_github_pins and github_pins %}
        {% include "github-pins.njk" %}
      {% endif %}
    </div>
  </div>
  
  {% if site.homepage.show_recent_posts %}
  <div class="recent-posts">
    <h2>Recent Blog Posts</h2>
    <ul class="post-list">
      {%- for post in collections.posts | reverse -%}
        {% if loop.index <= site.homepage.recent_posts_count %}
          {% include "post-list-item.njk" %}
        {% endif %}
      {%- endfor -%}
    </ul>
    <div class="view-all-posts">
      <a href="/blog/" class="back-link">View all posts <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/></svg></a>
    </div>
  </div>
  {% endif %}
  
  {% if site.homepage.show_arxiv_papers and arxiv_feed %}
    {% include "arxiv-papers.njk" %}
  {% endif %}
</div>