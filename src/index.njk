---
layout: _layouts/base.njk
title: Home
permalink: /
eleventyNavigation:
  key: Home
  order: 1
---
<div class="home-content">
  {% include "page-header.njk" %}
  {% if site.homepage.show_terminal %}
  {% set skillsList = [] %}
  {% for skill in site.homepage.skills %}
    {% set skillsList = (skillsList.push(skill), skillsList) %}
  {% endfor %}
  
  {% set projectsHtml %}
    <div class="file-listing">
      {% for link in site.links %}
        {% if link.group == "Projects" %}
        <div class="file">
          <span class="file-name"><a href="{{ link.url }}" target="_blank">{{ link.name }}</a></span>
          <span class="file-desc">{{ link.description }}</span>
        </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endset %}
  
  {% set homeCommands = [
    {
      command: 'whoami',
      type: 'text',
      response: 'I\'m a software engineer specializing in cloud architecture, cybersecurity, and AI/ML applications. With experience across the full development lifecycle, I build robust, scalable solutions that solve complex problems.'
    },
    {
      command: 'skills --list',
      type: 'list',
      response: site.homepage.skills
    },
    {
      command: 'cat interests.txt',
      type: 'text',
      response: site.homepage.interests
    },
    {
      command: 'ls projects/',
      type: 'html',
      response: projectsHtml
    }
  ] %}
  
  {% include "terminal.njk" %}
  {% endif %}
  
  {% if site.homepage.show_github_pins and github_pins %}
    {% include "github-pins.njk" %}
  {% endif %}

  {% if site.homepage.show_recent_posts %}
  <div class="recent-posts">
    <h2>Recent Blog Posts</h2>
    <ul class="post-list">
      {%- for post in collections.posts | reverse -%}
        {% if loop.index <= site.homepage.recent_posts_count %}
          {% include "post-list-item.njk" %}
        {% endif %}
      {%- endfor -%}
    </ul>
    <div class="view-all-posts">
      <a href="/blog/" class="social-btn">View all posts <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/></svg></a>
    </div>
  </div>
  {% endif %}
  
  {% if site.homepage.show_arxiv_papers and arxiv_feed %}
    {% include "arxiv-papers.njk" %}
  {% endif %}
</div>