---
layout: layouts/base.njk
title: Home
description: Welcome to my personal website featuring my portfolio, blog, and curated links.
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">{{ site.author }}</h1>
      <p class="hero-subtitle">Welcome to my personal corner of the internet</p>
      <div class="hero-buttons">
        <a href="/projects/" class="btn btn-primary">View My Work</a>
        <a href="/about/" class="btn btn-secondary">About Me</a>
      </div>
    </div>
  </div>
</section>

{% include "components/latest-post.njk" %}

<section class="featured-projects">
  <div class="container">
    <h2 class="section-title">Featured Projects</h2>

    <div class="project-grid">
      {% set featuredProjects = collections.project | head(3) %} {% for project
      in featuredProjects %}
      <div class="project-card">
        {% if project.data.image %}
        <div class="project-image">
          <a href="{{ project.url }}">
            <img
              src="{{ project.data.image }}"
              alt="{{ project.data.title }}"
            />
          </a>
        </div>
        {% endif %}

        <div class="project-content">
          <h3 class="project-title">
            <a href="{{ project.url }}">{{ project.data.title }}</a>
          </h3>

          {% if project.data.description %}
          <p class="project-excerpt">{{ project.data.description }}</p>
          {% endif %}

          <a href="{{ project.url }}" class="read-more"
            >View Project <i class="fas fa-arrow-right"></i
          ></a>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="section-footer">
      <a href="/projects/" class="btn btn-outline">View All Projects</a>
    </div>
  </div>
</section>

<section class="featured-links">
  <div class="container">
    <h2 class="section-title">Recently Curated Links</h2>

    <div class="links-grid">
      {% set allLinks = [] %} {% for category in links.categories %} {% for link
      in category.items %} {% set linkWithCategory = link %} {% set
      linkWithCategory = linkWithCategory | merge({"category": category.name})
      %} {% set allLinks = allLinks | push(linkWithCategory) %} {% endfor %} {%
      endfor %} {% set sortedLinks = allLinks | sort(true, false, "date") |
      head(4) %} {% for link in sortedLinks %}
      <div class="link-card">
        <div class="link-content">
          <span class="link-category">{{ link.category }}</span>
          <h3 class="link-title">
            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
              >{{ link.title }}</a
            >
          </h3>

          {% if link.description %}
          <p class="link-description">{{ link.description }}</p>
          {% endif %}

          <div class="link-meta">
            <time datetime="{{ link.date }}">{{ link.date | formatDate }}</time>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="section-footer">
      <a href="/links/" class="btn btn-outline">Browse All Links</a>
    </div>
  </div>
</section>
