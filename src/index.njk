---
layout: base.njk
title: Home
permalink: /
eleventyNavigation:
  key: Home
  order: 1
---
<div class="gh-profile-header">
  <div class="gh-avatar-container">
    <img src="/assets/images/github-style/profile-avatar.svg" alt="{{ site.title }}" class="gh-avatar">
    
    <div class="gh-profile-stats mt-4">
      <div class="gh-stat">
        <svg aria-hidden="true" class="gh-stat-icon" height="16" viewBox="0 0 16 16" version="1.1" width="16">
          <path fill-rule="evenodd" d="M5.5 3.5a2 2 0 100 4 2 2 0 000-4zM2 5.5a3.5 3.5 0 115.898 2.549 5.507 5.507 0 013.034 4.084.75.75 0 11-1.482.235 4.001 4.001 0 00-7.9 0 .75.75 0 01-1.482-.236A5.507 5.507 0 013.102 8.05 3.49 3.49 0 012 5.5zM11 4a.75.75 0 100 1.5 1.5 1.5 0 01.666 2.844.75.75 0 00-.416.672v.352a.75.75 0 00.574.73c1.2.289 2.162 1.2 2.522 2.372a.75.75 0 101.434-.44 5.01 5.01 0 00-2.56-3.012A3 3 0 0011 4z"></path>
        </svg>
        <span class="gh-stat-count">15</span>
        <span class="gh-stat-label">followers</span>
      </div>
      <span>·</span>
      <div class="gh-stat">
        <span class="gh-stat-count">32</span>
        <span class="gh-stat-label">following</span>
      </div>
      <span>·</span>
      <div class="gh-stat">
        <svg aria-hidden="true" class="gh-stat-icon" height="16" viewBox="0 0 16 16" version="1.1" width="16">
          <path fill-rule="evenodd" d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25zm0 2.445L6.615 5.5a.75.75 0 01-.564.41l-3.097.45 2.24 2.184a.75.75 0 01.216.664l-.528 3.084 2.769-1.456a.75.75 0 01.698 0l2.77 1.456-.53-3.084a.75.75 0 01.216-.664l2.24-2.183-3.096-.45a.75.75 0 01-.564-.41L8 2.694v.001z"></path>
        </svg>
        <span class="gh-stat-count">18</span>
      </div>
    </div>
  </div>
  
  <div class="gh-profile-content">
    <div class="gh-profile-header-info">
      <h1 class="gh-name">{{ site.title }}</h1>
      <div class="gh-username text-text-secondary">{{ site.homepage.welcome_subtitle }}</div>
      <p class="gh-bio">{{ site.description }}</p>
      
      <div class="flex gap-2">
        <a href="mailto:{{ site.email }}" class="gh-btn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0114.25 14H1.75A1.75 1.75 0 010 12.25v-8.5C0 2.784.784 2 1.75 2zM1.5 12.251c0 .138.112.25.25.25h12.5a.25.25 0 00.25-.25V5.809L8.38 9.397a.75.75 0 01-.76 0L1.5 5.809v6.442zm13-8.181v-.32a.25.25 0 00-.25-.25H1.75a.25.25 0 00-.25.25v.32L8 7.88l6.5-3.81z"></path></svg>
          Contact me
        </a>
        <a href="/blog/" class="gh-btn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M0 1.75A.75.75 0 01.75 1h14.5a.75.75 0 010 1.5H.75A.75.75 0 010 1.75zm0 5A.75.75 0 01.75 6h14.5a.75.75 0 010 1.5H.75A.75.75 0 010 6.75zm0 5A.75.75 0 01.75 11h14.5a.75.75 0 010 1.5H.75a.75.75 0 01-.75-.75z"></path></svg>
          Blog posts
        </a>
      </div>
    </div>
    
    <div>
      <h2>About Me</h2>
      <p>I'm a software engineer specializing in cloud architecture, cybersecurity, and AI/ML applications. With experience across the full development lifecycle, I build robust, scalable solutions that solve complex problems.</p>

      <h3>Skills & Expertise</h3>
      <img src="/assets/images/github-style/tech-icons.svg" alt="Technology skills icons" class="w-full mb-4 border border-border rounded-github p-2 bg-surface">
      <div class="gh-skills-grid">
        {% for skill in site.homepage.skills %}
          <div class="gh-skill-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0zm7-3.25v2.992l2.028.812a.75.75 0 01-.557 1.392l-2.5-1A.751.751 0 017 8.25v-3.5a.75.75 0 011.5 0z"></path></svg>
            {{ skill }}
          </div>
        {% endfor %}
      </div>
      
      <h3>Interests</h3>
      <p>{{ site.homepage.interests }}</p>

      <h3 class="mt-6">Contributions</h3>
      <div class="border border-border rounded-github overflow-hidden p-2 bg-surface">
        <img src="/assets/images/github-style/contribution-graph.svg" alt="Contribution graph" class="w-full">
        <div class="mt-2 text-xs text-text-secondary flex items-center justify-end">
          <span class="mr-1">Contribution activity</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
            <path d="M8 16.5a.5.5 0 0 1-.5-.5v-1.5h-2A2.5 2.5 0 0 1 3 12V8.5H1.5a.5.5 0 0 1 0-1H3V4a2.5 2.5 0 0 1 2.5-2.5h4A2.5 2.5 0 0 1 12 4v3.5h1.5a.5.5 0 0 1 0 1H12V12a2.5 2.5 0 0 1-2.5 2.5h-2V16a.5.5 0 0 1-.5.5Zm-2-4h4a1.5 1.5 0 0 0 1.5-1.5v-7A1.5 1.5 0 0 0 10 2.5H6A1.5 1.5 0 0 0 4.5 4v7A1.5 1.5 0 0 0 6 12.5Z"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>

{% if site.homepage.show_github_pins and github_pins %}
<div class="gh-pinned-repos">
  <div class="gh-section-header">
    <h2 class="gh-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" class="mr-2" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 011-1h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"></path></svg>
      Pinned repositories
    </h2>
    <a href="https://github.com/williamzujkowski?tab=repositories" class="gh-btn">
      <span>See all</span>
    </a>
  </div>
  
  <div class="gh-repos-grid">
    {% for repo in github_pins %}
      <div class="gh-repo-card">
        {% if loop.index <= 3 %}
        <div class="mb-3 -mx-4 -mt-4">
          <img src="/assets/images/github-style/repo-card-{{ loop.index }}.svg" class="w-full rounded-t-github" alt="Repository image for {{ repo.name }}">
        </div>
        {% endif %}
        <a href="{{ repo.url }}" class="gh-repo-name">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" class="mr-2" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 011-1h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"></path></svg>
          {{ repo.name }}
        </a>
        
        <div class="gh-repo-description">{{ repo.description }}</div>
        
        <div class="gh-repo-meta">
          {% if repo.language %}
          <div class="gh-repo-language">
            <span class="gh-language-color" style="background-color: {{ repo.language_color }}"></span>
            <span>{{ repo.language }}</span>
          </div>
          {% endif %}
          
          {% if repo.stars > 0 %}
          <div class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" class="mr-1" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25zm0 2.445L6.615 5.5a.75.75 0 01-.564.41l-3.097.45 2.24 2.184a.75.75 0 01.216.664l-.528 3.084 2.769-1.456a.75.75 0 01.698 0l2.77 1.456-.53-3.084a.75.75 0 01.216-.664l2.24-2.183-3.096-.45a.75.75 0 01-.564-.41L8 2.694v.001z"></path></svg>
            {{ repo.stars }}
          </div>
          {% endif %}
          
          {% if repo.forks > 0 %}
          <div class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" class="mr-1" fill="currentColor"><path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75v-.878a2.25 2.25 0 111.5 0v.878a2.25 2.25 0 01-2.25 2.25h-1.5v2.128a2.251 2.251 0 11-1.5 0V8.5h-1.5A2.25 2.25 0 013 6.25v-.878a2.25 2.25 0 111.5 0zM5 3.25a.75.75 0 10-1.5 0 .75.75 0 001.5 0zm6.75.75a.75.75 0 100-1.5.75.75 0 000 1.5zm-3 8.75a.75.75 0 10-1.5 0 .75.75 0 001.5 0z"></path></svg>
            {{ repo.forks }}
          </div>
          {% endif %}
          
          {% if repo.updated %}
          <div>Updated {{ repo.updated }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<div class="gh-section-header">
  <h2 class="gh-section-title text-white flex items-center">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="20" height="20" fill="currentColor" class="mr-2"><path d="M0 1.75A.75.75 0 01.75 1h14.5a.75.75 0 010 1.5H.75A.75.75 0 010 1.75zm0 5A.75.75 0 01.75 6h14.5a.75.75 0 010 1.5H.75A.75.75 0 010 6.75zm0 5A.75.75 0 01.75 11h14.5a.75.75 0 010 1.5H.75a.75.75 0 01-.75-.75z"></path></svg>
    Recent Blog Posts
  </h2>
  <a href="/blog/" class="gh-btn">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="mr-1.5">
      <path d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0z"></path>
      <path d="M9 11.75a.75.75 0 01-.75.75h-.5a.75.75 0 010-1.5h.5a.75.75 0 01.75.75zM9 8a.75.75 0 01-.75.75h-.5a.75.75 0 010-1.5h.5A.75.75 0 019 8zM8.25 5.75a.75.75 0 00-.5 1.5h.5a.75.75 0 000-1.5h-.5z"></path>
    </svg>
    <span>View all</span>
  </a>
</div>

<ul class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
  {%- for post in collections.posts | reverse -%}
    {% if loop.index <= 3 %}
      <li class="gh-post-item">
        <div class="gh-post-image">
          {% if "ai" in post.data.tags %}
            <img src="/assets/images/blog/ai-blog.jpg" alt="AI blog illustration">
          {% elif "security" in post.data.tags %}
            <img src="/assets/images/blog/security-blog.jpg" alt="Security blog illustration">
          {% elif "cloud" in post.data.tags %}
            <img src="/assets/images/blog/cloud-blog.jpg" alt="Cloud computing blog illustration">
          {% elif post.data.title and "Pizza" in post.data.title %}
            <img src="/assets/images/blog/pizza-blog.jpg" alt="Developer pizza blog illustration">
          {% elif "transformer" in post.data.tags %}
            <img src="/assets/images/blog/transformer-blog.jpg" alt="Transformer architecture blog illustration">
          {% elif "ethics" in post.data.tags %}
            <img src="/assets/images/blog/ethics-blog.jpg" alt="AI ethics blog illustration">
          {% else %}
            <img src="/assets/images/github-style/blog-placeholder.svg" alt="Blog post illustration">
          {% endif %}
        </div>
        <div class="gh-post-content">
          <a href="{{ post.url }}" class="gh-post-title">{{ post.data.title }}</a>
          
          <div class="gh-post-date">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="14" height="14" fill="currentColor">
              <path d="M4.75 0a.75.75 0 01.75.75V2h5V.75a.75.75 0 011.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0113.25 16H2.75A1.75 1.75 0 011 14.25V3.75C1 2.784 1.784 2 2.75 2H4V.75A.75.75 0 014.75 0zm0 3.5h8.5a.25.25 0 01.25.25V6h-9V3.75a.25.25 0 01.25-.25zm-2 3h10.5v7.75a.25.25 0 01-.25.25H2.75a.25.25 0 01-.25-.25V6.5z"></path>
            </svg>
            {{ post.date | readableDate }}
          </div>
          
          <div class="gh-post-excerpt">
            {% if post.data.description %}
              {{ post.data.description }}
            {% else %}
              {{ post.templateContent | striptags | truncate(120) }}
            {% endif %}
          </div>
          
          {% if post.data.tags %}
            <div class="gh-post-tags">
              {% for tag in post.data.tags %}
                {% if tag != "posts" %}
                  <span class="gh-badge gh-badge-accent">{{ tag }}</span>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
          
          <a href="{{ post.url }}" class="gh-read-more">
            Read more
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
              <path d="M8.22 2.97a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06l2.97-2.97H3.75a.75.75 0 010-1.5h7.44L8.22 4.03a.75.75 0 010-1.06z"></path>
            </svg>
          </a>
        </div>
      </li>
    {% endif %}
  {%- endfor -%}
</ul>

{% if site.homepage.show_arxiv_papers and arxiv_feed %}
<div class="mt-8">
  <div class="gh-section-header">
    <h2 class="gh-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" class="mr-2" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 011-1h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"></path></svg>
      Recent Publications
    </h2>
  </div>
  
  <div class="gh-post-list">
    {% for paper in arxiv_feed %}
      <div class="gh-post-item">
        <a href="{{ paper.link }}" class="gh-post-title">{{ paper.title }}</a>
        <div class="gh-post-date">{{ paper.date }}</div>
        <div class="gh-post-excerpt">{{ paper.summary | truncate(150) }}</div>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}