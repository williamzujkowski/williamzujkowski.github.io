---
layout: base.njk
title: Home
permalink: /
eleventyNavigation:
  key: Home
  order: 1
---
<div class="home-content">
  <header class="home-header">
    <h1>{{ site.homepage.welcome_heading }}</h1>
    <p>{{ site.homepage.welcome_subtitle }}</p>
  </header>

  
  {% if site.homepage.show_terminal %}
  <div class="terminal-box">
    <div class="terminal-header">{{ site.homepage.terminal_prompt }}</div>
    <div class="terminal-content">
      <div class="command-line">
        <span class="prompt">$</span>
        <span class="command">whoami</span>
      </div>
      <div class="response">
        <p>I'm a software engineer specializing in cloud architecture, cybersecurity, and AI/ML applications. With experience across the full development lifecycle, I build robust, scalable solutions that solve complex problems.</p>
      </div>
      
      <div class="command-line">
        <span class="prompt">$</span>
        <span class="command">skills --list</span>
      </div>
      <div class="response">
        <ul>
          {% for skill in site.homepage.skills %}
          <li>{{ skill }}</li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="command-line">
        <span class="prompt">$</span>
        <span class="command">cat interests.txt</span>
      </div>
      <div class="response">
        <p>{{ site.homepage.interests }}</p>
      </div>
      
      <div class="command-line">
        <span class="prompt">$</span>
        <span class="command">ls projects/</span>
      </div>
      <div class="response">
        <div class="file-listing">
          {% for link in site.links %}
            {% if link.group == "Projects" %}
            <div class="file">
              <span class="file-name"><a href="{{ link.url }}" target="_blank">{{ link.name }}</a></span>
              <span class="file-desc">{{ link.description }}</span>
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  {% endif %}
  
  {% if site.homepage.show_recent_posts %}
  <div class="recent-posts">
    <h2>Recent Blog Posts</h2>
    <ul class="post-list">
      {%- for post in collections.posts | reverse -%}
        {% if loop.index <= site.homepage.recent_posts_count %}
          <li class="post-item">
            <h3 class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
            <time class="post-date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
            <div class="post-excerpt">
              <p>{{ post.data.description or post.templateContent | striptags | truncate(150) }}</p>
            </div>
            <a href="{{ post.url }}" class="read-more">Read more &rarr;</a>
          </li>
        {% endif %}
      {%- endfor -%}
    </ul>
    <div class="view-all-posts">
      <a href="/blog/" class="social-btn">View all posts <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/></svg></a>
    </div>
  </div>
  {% endif %}
</div>