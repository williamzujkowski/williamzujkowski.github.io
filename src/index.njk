---
layout: base.njk
title: Home
permalink: /
eleventyNavigation:
  key: Home
  order: 1
---
<!-- Desktop Layout -->
<div class="hidden md:block">
  <div class="gh-profile-header">
    <div class="gh-avatar-container">
      <img src="/assets/images/github-style/profile-avatar.png" alt="{{ site.title }}" class="gh-avatar">
      
      <div class="flex flex-col space-y-2 w-full md:w-[296px] max-w-full md:max-w-[296px] mx-auto md:mx-0">
        <div>
          <h3 class="text-xl md:text-lg text-center md:text-left font-medium mb-2">{{ site.homepage.about_me_title }}</h3>
          <div class="bg-surface rounded-github border border-border p-4 transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg">
            <p class="text-base md:text-sm text-center md:text-left leading-relaxed mb-0">{{ site.homepage.about_me_content }}</p>
          </div>
        </div>
        
        <div>
          <h3 class="text-xl md:text-lg text-center md:text-left font-medium mb-2">Interests</h3>
          <div class="bg-surface rounded-github border border-border p-4 transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg">
            <p class="text-base md:text-sm text-center md:text-left leading-relaxed mb-0">{{ site.homepage.interests }}</p>
          </div>
        </div>
        
        <div>
          <h3 class="text-xl md:text-lg text-center md:text-left font-medium mb-2">GitHub Activity</h3>
          <div class="bg-surface rounded-github border border-border p-4 transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg">
            <img src="https://github-readme-stats.vercel.app/api?username=williamzujkowski&show_icons=true&theme=github_dark&hide_border=true&count_private=true&card_width=296&hide_title=true&hide_rank=true&include_all_commits=false&show_owner=true&cache_seconds=86400&text_bold=false" alt="GitHub Stats" class="hover:opacity-95 transition-all duration-300 mx-auto" />
          </div>
        </div>
      </div>
    </div>
    
    <div class="gh-profile-content">
      <div class="gh-profile-header-info">
        <h1 class="gh-name">{{ site.title }}</h1>
        <div class="gh-username text-text-secondary">{{ site.homepage.welcome_subtitle }}</div>
        <p class="gh-bio">{{ site.description }}</p>
      </div>
      
      <div>
        <h2 class="text-center md:text-left relative pb-2 mb-4 after:content-[''] after:absolute after:bottom-0 after:left-0 after:right-0 after:mx-auto md:after:mx-0 after:w-12 after:h-0.5 after:bg-accent/30">Latest Blog Posts</h2>
        <div class="gh-featured-projects mb-6 grid grid-cols-1 md:grid-cols-2 gap-4">
          {% set latestPosts = collections.posts | reverse %}
          {% for post in latestPosts.slice(0, 2) %}
            <a href="{{ post.url }}" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-github">
              <div class="gh-project-card bg-surface border border-border rounded-github p-4 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
                <div class="mb-2 flex-grow">
                  <div class="text-lg font-medium text-white transition-colors duration-200 hover:text-accent">{{ post.data.title }}</div>
                </div>
                <p class="gh-project-description text-xs text-text mb-3 pointer-events-none line-clamp-2">
                  {% set postContent = post.templateContent | striptags %}
                  {{ postContent | truncate(150) }}
                </p>
                <div class="flex justify-between items-center">
                  <div class="gh-project-tags flex flex-wrap gap-2 pointer-events-none">
                    {% if post.data.tags %}
                      {% for tag in post.data.tags %}
                        {% if tag != "posts" %}
                          <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">{{ tag }}</span>
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  </div>
                  <div class="text-xs text-text-secondary">{{ post.date | date("MMM d, yyyy") }}</div>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>
        
        {% if site.homepage.show_featured_projects !== false %}
        <h2 class="text-center md:text-left relative pb-2 mb-4 after:content-[''] after:absolute after:bottom-0 after:left-0 after:right-0 after:mx-auto md:after:mx-0 after:w-12 after:h-0.5 after:bg-accent/30">Featured Projects</h2>
        <div class="gh-featured-projects mb-6 grid grid-cols-1 md:grid-cols-2 gap-4">
          <a href="https://github.com/williamzujkowski/cloud-security-framework" target="_blank" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-github">
            <div class="gh-project-card bg-surface border border-border rounded-github p-4 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
              <div class="mb-2 flex-grow">
                <div class="text-lg font-medium text-white transition-colors duration-200">Cloud Security Framework</div>
              </div>
              <p class="gh-project-description text-xs text-text mb-3 pointer-events-none line-clamp-2">A comprehensive security architecture for cloud-native applications with zero-trust principles and automated compliance monitoring.</p>
              <div class="gh-project-tags flex flex-wrap gap-2 pointer-events-none">
                <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">AWS</span>
                <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">Security</span>
                <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">DevSecOps</span>
              </div>
            </div>
          </a>
          
          <a href="https://github.com/williamzujkowski/rag-knowledge-base" target="_blank" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-github">
            <div class="gh-project-card bg-surface border border-border rounded-github p-4 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
              <div class="mb-2 flex-grow">
                <div class="text-lg font-medium text-white transition-colors duration-200">RAG-Powered Knowledge Base</div>
              </div>
              <p class="gh-project-description text-xs text-text mb-3 pointer-events-none line-clamp-2">An intelligent documentation system that uses Retrieval Augmented Generation to provide context-aware responses to technical questions.</p>
              <div class="gh-project-tags flex flex-wrap gap-2 pointer-events-none">
                <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">AI</span>
                <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">NLP</span>
                <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">Vector DB</span>
              </div>
            </div>
          </a>
        </div>
        {% endif %}
        
        <h3 class="text-center md:text-left relative pb-2 mb-3 after:content-[''] after:absolute after:bottom-0 after:left-0 after:right-0 after:mx-auto md:after:mx-0 after:w-12 after:h-0.5 after:bg-accent/30">Current Reading</h3>
        {% include "books-section.njk" %}
        
        <h3 class="text-center md:text-left relative pb-2 mb-3 mt-8 after:content-[''] after:absolute after:bottom-0 after:left-0 after:right-0 after:mx-auto md:after:mx-0 after:w-12 after:h-0.5 after:bg-accent/30">Research Papers</h3>
        <!-- Debug: {{ current_reading | dump }} -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {% if current_reading and current_reading.length > 0 %}
            {% for paper in current_reading %}
              <a href="{{ paper.link }}" target="_blank" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-github">
                <div class="bg-surface rounded-github border border-border p-4 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
                  <div class="mb-2 flex-grow">
                    <div class="text-lg font-medium text-white transition-colors duration-200 group-hover:text-accent">{{ paper.title }}</div>
                  </div>
                  <div class="flex flex-wrap items-center gap-2 mb-3 pointer-events-none">
                    <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">{{ paper.categoryLabel }}</span>
                    <div class="text-sm text-text-secondary">{{ paper.firstAuthor }}</div>
                    {% if paper.formattedDate %}
                      <div class="text-xs text-text-secondary opacity-75">{{ paper.formattedDate }}</div>
                    {% endif %}
                  </div>
                  <div class="text-xs text-text line-clamp-2 mb-3 pointer-events-none">
                    {% if paper.summary %}
                      {{ paper.summary | truncate(150) }}
                    {% endif %}
                  </div>
                  <div class="w-full bg-gray-light rounded-full h-1.5 mb-1 pointer-events-none">
                    <div class="bg-accent h-full rounded-full" style="width: {{ paper.progress }}%"></div>
                  </div>
                  <div class="flex justify-between items-center pointer-events-none">
                    <div class="text-xs text-text-secondary">{{ paper.progress }}% complete</div>
                    <div class="text-xs text-accent font-medium">Read on arXiv</div>
                  </div>
                </div>
              </a>
            {% endfor %}
          {% elif site.homepage.show_arxiv_papers and arxiv_feed and arxiv_feed.length > 0 %}
            <!-- Fallback to arxiv_feed if current_reading is empty -->
            {% for paper in arxiv_feed %}
              {% if loop.index <= 2 %}
                <a href="{{ paper.link }}" target="_blank" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-github">
                  <div class="bg-surface rounded-github border border-border p-4 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
                    <div class="mb-2 flex-grow">
                      <div class="text-lg font-medium text-white transition-colors duration-200 group-hover:text-accent">{{ paper.title }}</div>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mb-3 pointer-events-none">
                      <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">{{ paper.categoryLabel }}</span>
                      <div class="text-sm text-text-secondary">{{ paper.firstAuthor }}</div>
                      {% if paper.formattedDate %}
                        <div class="text-xs text-text-secondary opacity-75">{{ paper.formattedDate }}</div>
                      {% endif %}
                    </div>
                    <div class="text-xs text-text line-clamp-2 mb-3 pointer-events-none">
                      {% if paper.summary %}
                        {{ paper.summary | truncate(150) }}
                      {% endif %}
                    </div>
                    <div class="w-full bg-gray-light rounded-full h-1.5 mb-1 pointer-events-none">
                      <div class="bg-accent h-full rounded-full" style="width: {% if paper.progress %}{{ paper.progress }}{% else %}30{% endif %}%"></div>
                    </div>
                    <div class="flex justify-between items-center pointer-events-none">
                      <div class="text-xs text-text-secondary">{% if paper.progress %}{{ paper.progress }}{% else %}30{% endif %}% complete</div>
                      <div class="text-xs text-accent font-medium">Read on arXiv</div>
                    </div>
                  </div>
                </a>
              {% endif %}
            {% endfor %}
          {% else %}
            <!-- Fallback content if no papers are available -->
            <a href="https://arxiv.org/abs/2403.17003" target="_blank" class="block h-full">
              <div class="bg-surface rounded-github border border-border p-4 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
                <div class="mb-2 flex-grow">
                  <div class="text-lg font-medium text-white">Quantum-Safe Cryptography: Post-Quantum Approaches</div>
                </div>
                <div class="flex flex-wrap items-center gap-2 mb-3 pointer-events-none">
                  <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">Security</span>
                  <div class="text-sm text-text-secondary">R. Avanzi et al.</div>
                </div>
                <div class="text-xs text-text line-clamp-2 mb-3 pointer-events-none">
                  Explores the standardization of cryptographic schemes that provide security against both quantum and classical computers.
                </div>
                <div class="w-full bg-gray-light rounded-full h-1.5 mb-1 pointer-events-none">
                  <div class="bg-accent h-full rounded-full" style="width: 65%"></div>
                </div>
                <div class="flex justify-between items-center pointer-events-none">
                  <div class="text-xs text-text-secondary">65% complete</div>
                  <div class="text-xs text-accent font-medium">Read on arXiv</div>
                </div>
              </div>
            </a>
            
            <a href="https://arxiv.org/abs/2404.01373" target="_blank" class="block h-full">
              <div class="bg-surface rounded-github border border-border p-4 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
                <div class="mb-2 flex-grow">
                  <div class="text-lg font-medium text-white">LLMs at the Edge: Efficient Fine-Tuning Methods</div>
                </div>
                <div class="flex flex-wrap items-center gap-2 mb-3 pointer-events-none">
                  <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">AI</span>
                  <div class="text-sm text-text-secondary">Chen et al.</div>
                </div>
                <div class="text-xs text-text line-clamp-2 mb-3 pointer-events-none">
                  Analysis of methods for deploying and fine-tuning large language models on resource-constrained edge devices.
                </div>
                <div class="w-full bg-gray-light rounded-full h-1.5 mb-1 pointer-events-none">
                  <div class="bg-accent h-full rounded-full" style="width: 42%"></div>
                </div>
                <div class="flex justify-between items-center pointer-events-none">
                  <div class="text-xs text-text-secondary">42% complete</div>
                  <div class="text-xs text-accent font-medium">Read on arXiv</div>
                </div>
              </div>
            </a>
          {% endif %}
        </div>
        
        {% if site.homepage.show_latest_learning !== false %}
        <h3 class="text-center md:text-left relative pb-2 mb-3 mt-8 after:content-[''] after:absolute after:bottom-0 after:left-0 after:right-0 after:mx-auto md:after:mx-0 after:w-12 after:h-0.5 after:bg-accent/30">Latest Learning</h3>
        <div class="gh-learning-timeline mb-6 pl-4 border-l border-border space-y-6">
          <div class="gh-timeline-item relative flex items-start">
            <div class="gh-timeline-icon absolute -left-8 bg-gray-light border-2 border-border rounded-full p-1.5 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
                <path d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0z"></path>
                <path d="M8 9.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path>
              </svg>
            </div>
            <div class="gh-timeline-content pl-2">
              <div class="gh-timeline-date text-xs text-text-secondary mb-1">November 2024</div>
              <div class="gh-timeline-title text-white font-medium mb-1">Large Language Model Fine-Tuning</div>
              <p class="gh-timeline-description text-sm text-text mb-2">Completed advanced course on fine-tuning large language models for domain-specific applications using LoRA and QLoRA techniques.</p>
            </div>
          </div>
          
          <div class="gh-timeline-item relative flex items-start">
            <div class="gh-timeline-icon absolute -left-8 bg-gray-light border-2 border-border rounded-full p-1.5 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
                <path d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0z"></path>
                <path d="M8 9.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path>
              </svg>
            </div>
            <div class="gh-timeline-content pl-2">
              <div class="gh-timeline-date text-xs text-text-secondary mb-1">October 2024</div>
              <div class="gh-timeline-title text-white font-medium mb-1">Zero-Knowledge Proof Implementation</div>
              <p class="gh-timeline-description text-sm text-text mb-2">Built a practical implementation of ZK-SNARKs for privacy-preserving authentication in web applications.</p>
            </div>
          </div>
        </div>
        {% endif %}
        
        <!-- Interests moved above -->
      </div>
    </div>
  </div>
</div>

<!-- Mobile Layout - Completely different -->
<div class="md:hidden">
  <!-- Mobile Header -->
  <div class="mobile-profile-header text-center mb-8">
    <img src="/assets/images/github-style/profile-avatar.png" alt="{{ site.title }}" class="w-40 h-40 rounded-full mx-auto mb-6 border-3 border-accent">
    
    <h1 class="text-3xl font-bold mb-2">{{ site.title }}</h1>
    <div class="text-xl text-text-secondary mb-6">{{ site.homepage.welcome_subtitle }}</div>
    
    <!-- About section -->
    <div class="flex flex-col space-y-6 mb-8">
      <div>
        <h2 class="text-2xl font-semibold mb-4">{{ site.homepage.about_me_title }}</h2>
        <div class="bg-surface p-6 rounded-github border border-border transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg">
          <p class="text-lg leading-relaxed mb-0">{{ site.homepage.about_me_content }}</p>
        </div>
      </div>
      
      <div>
        <h3 class="text-2xl font-semibold mb-4">Interests</h3>
        <div class="bg-surface p-6 rounded-github border border-border transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg">
          <p class="text-lg leading-relaxed mb-0">{{ site.homepage.interests }}</p>
        </div>
      </div>
    </div>
    
    <!-- GitHub Stats -->
    <div class="mb-10">
      <h3 class="text-2xl font-semibold mb-4 text-center">GitHub Activity</h3>
      <div class="bg-surface p-6 rounded-github border border-border transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg">
        <img src="https://github-readme-stats.vercel.app/api?username=williamzujkowski&show_icons=true&theme=github_dark&hide_border=true&count_private=true&card_width=220&hide_title=true&hide_rank=true&include_all_commits=false&show_owner=true&cache_seconds=86400&text_bold=false" alt="GitHub Stats" class="hover:opacity-95 transition-all duration-300 mx-auto" />
      </div>
    </div>
  </div>
  
  <!-- Latest Blog Posts Section -->
  <div class="mb-10">
    <h2 class="text-2xl font-bold mb-6 text-center">Latest Blog Posts</h2>
    
    <div class="grid grid-cols-1 gap-6">
      {% set latestPosts = collections.posts | reverse %}
      {% for post in latestPosts.slice(0, 2) %}
        <a href="{{ post.url }}" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-lg">
          <div class="bg-surface rounded-lg p-6 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg border border-border">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
            <div class="mb-3">
              <div class="text-xl font-medium text-white transition-colors duration-200 hover:text-accent">{{ post.data.title }}</div>
              <div class="text-sm text-text-secondary mt-1">{{ post.date | date("MMM d, yyyy") }}</div>
            </div>
            <p class="text-sm text-text mb-4 line-clamp-3">
              {% set postContent = post.templateContent | striptags %}
              {{ postContent | truncate(150) }}
            </p>
            <div class="flex flex-wrap gap-2 mt-auto">
              {% if post.data.tags %}
                {% for tag in post.data.tags %}
                  {% if tag != "posts" %}
                    <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded-sm text-sm">{{ tag }}</span>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
  
  {% if site.homepage.show_featured_projects !== false %}
  <!-- Featured Projects Section -->
  <div class="mb-10">
    <h2 class="text-2xl font-bold mb-6 text-center">Featured Projects</h2>
    
    <div class="grid grid-cols-1 gap-6">
      <!-- Project 1 -->
      <a href="https://github.com/williamzujkowski/cloud-security-framework" target="_blank" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-lg">
        <div class="bg-surface rounded-lg p-6 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg border border-border">
          <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
          <div class="mb-2 flex-grow">
            <div class="text-xl font-medium text-white transition-colors duration-200">Cloud Security Framework</div>
          </div>
          <p class="text-sm text-text mb-4 line-clamp-3 pointer-events-none">A comprehensive security architecture for cloud-native applications with zero-trust principles and automated compliance monitoring.</p>
          <div class="flex flex-wrap gap-2 pointer-events-none">
            <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded-sm text-sm">AWS</span>
            <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded-sm text-sm">Security</span>
            <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded-sm text-sm">DevSecOps</span>
          </div>
        </div>
      </a>
      
      <!-- Project 2 -->
      <a href="https://github.com/williamzujkowski/rag-knowledge-base" target="_blank" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-lg">
        <div class="bg-surface rounded-lg p-6 relative overflow-hidden h-full flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg border border-border">
          <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-accent to-primary pointer-events-none"></div>
          <div class="mb-2 flex-grow">
            <div class="text-xl font-medium text-white transition-colors duration-200">RAG-Powered Knowledge Base</div>
          </div>
          <p class="text-sm text-text mb-4 line-clamp-3 pointer-events-none">An intelligent documentation system that uses Retrieval Augmented Generation to provide context-aware responses to technical questions.</p>
          <div class="flex flex-wrap gap-2 pointer-events-none">
            <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded-sm text-sm">AI</span>
            <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded-sm text-sm">NLP</span>
            <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent rounded-sm text-sm">Vector DB</span>
          </div>
        </div>
      </a>
    </div>
  </div>
  {% endif %}
  
  <!-- Current Reading Section -->
  <div class="mb-10">
    <h2 class="text-2xl font-bold mb-6 text-center">Current Reading</h2>
    
    <!-- Books Section -->
    {% include "books-section.njk" %}
    
    <!-- Research Papers Section -->
    <h3 class="text-2xl font-bold mb-6 mt-10 text-center">Research Papers</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {% if current_reading and current_reading.length > 0 %}
        {% for paper in current_reading %}
