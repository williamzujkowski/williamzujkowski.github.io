<footer class="gh-footer">
  <div class="gh-footer-inner">
    <div class="gh-footer-links">
      <a href="/">&copy; {% year %} {{ site.author }}</a>
      <a href="https://www.11ty.dev/">Built with 11ty</a>
      <a href="/feed.xml">RSS</a>
    </div>
    
    <div class="footer-social flex items-center gap-3">
      {% for social in site.social_media %}
        {% if social.display_in_footer and social.enabled %}
          <a 
            href="{{ social.url }}" 
            class="text-text-secondary hover:text-theme-accent transition-colors duration-300" 
            aria-label="{{ social.name }}"
            title="{{ social.name }}"
          >{{ social.icon | safe }}</a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
  
  <div class="gh-copyright text-center text-xs text-text-secondary py-2 opacity-80">
    Designed with <span class="text-theme-accent">❤️</span> using TailwindCSS
  </div>
</footer>