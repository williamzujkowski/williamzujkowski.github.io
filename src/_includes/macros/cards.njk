{# Macro for post card #} {% macro postCard(post, featured=false) %}
<div class="gh-post-item {% if featured %}featured{% endif %}">
  <div class="gh-post-image">
    {% if blogImage %} {% set blogImg = blogImage(post) %} {% image blogImg.path,
    blogImg.alt, "(min-width: 768px) 33vw, 100vw", [400, 600] %} {% else %}
    <img
      src="/assets/images/github-style/blog-placeholder.jpg"
      alt="Blog post illustration"
      class="w-full h-full object-cover"
    />
    {% endif %}
  </div>
  <div class="gh-post-content">
    <a href="{{ post.url }}" class="gh-post-title">{{ post.data.title }}</a>

    <div class="gh-post-date">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        width="14"
        height="14"
        fill="currentColor"
      >
        <path
          d="M4.75 0a.75.75 0 01.75.75V2h5V.75a.75.75 0 011.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0113.25 16H2.75A1.75 1.75 0 011 14.25V3.75C1 2.784 1.784 2 2.75 2H4V.75A.75.75 0 014.75 0zm0 3.5h8.5a.25.25 0 01.25.25V6h-9V3.75a.25.25 0 01.25-.25zm-2 3h10.5v7.75a.25.25 0 01-.25.25H2.75a.25.25 0 01-.25-.25V6.5z"
        ></path>
      </svg>
      {{ post.date | readableDate }}
    </div>

    <a href="{{ post.url }}" class="gh-read-more">
      Read more
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        width="16"
        height="16"
        fill="currentColor"
      >
        <path
          d="M8.22 2.97a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06l2.97-2.97H3.75a.75.75 0 010-1.5h7.44L8.22 4.03a.75.75 0 010-1.06z"
        ></path>
      </svg>
    </a>
  </div>
</div>
{% endmacro %} {# Macro for link card #} {% macro linkCard(link) %}
<div class="gh-link-item">
  <div class="gh-link-image">
    {% if link.screenshot %}
    <img
      src="{{ link.screenshot }}"
      alt="{{ link.title }}"
      class="w-full h-full object-cover"
    />
    {% else %}
    <div class="gh-link-placeholder">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        width="16"
        height="16"
        fill="currentColor"
      >
        <path
          d="M7.775 3.275a.75.75 0 001.06 1.06l1.25-1.25a2 2 0 112.83 2.83l-2.5 2.5a2 2 0 01-2.83 0 .75.75 0 00-1.06 1.06 3.5 3.5 0 004.95 0l2.5-2.5a3.5 3.5 0 00-4.95-4.95l-1.25 1.25zm-4.69 9.64a2 2 0 010-2.83l2.5-2.5a2 2 0 012.83 0 .75.75 0 001.06-1.06 3.5 3.5 0 00-4.95 0l-2.5 2.5a3.5 3.5 0 004.95 4.95l1.25-1.25a.75.75 0 00-1.06-1.06l-1.25 1.25a2 2 0 01-2.83 0z"
        ></path>
      </svg>
    </div>
    {% endif %}
  </div>
  <div class="gh-link-content">
    <a
      href="{{ link.url }}"
      class="gh-link-title"
      target="_blank"
      rel="noopener noreferrer"
      >{{ link.title }}</a
    >
    <p class="gh-link-description">{{ link.description }}</p>
    <div class="gh-link-meta">
      <span class="gh-link-category">{{ link.category }}</span>
    </div>
  </div>
</div>
{% endmacro %}
