<section class="arxiv-papers mb-8">
  <h2 class="text-2xl font-bold mb-4 text-primary-light dark:text-primary-dark">Latest Research</h2>
  <div class="terminal-box">
    <div class="terminal-header">Recent AI/ML & Cybersecurity Papers</div>
    <div class="terminal-content">
      {% if arxiv_feed %}
        <div class="papers-list">
          {% for paper in arxiv_feed %}
            <div class="paper-item mb-4 p-3 bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark rounded">
              <h3 class="text-lg font-bold">
                <a href="{{ paper.link }}" target="_blank" rel="noopener" class="text-primary-light dark:text-primary-dark hover:underline">
                  {{ paper.title }}
                </a>
              </h3>
              <div class="paper-meta text-sm text-text-light dark:text-text-dark opacity-75 mb-2">
                <span class="category-label font-bold">{{ paper.categoryLabel }}</span> • 
                <span class="published-date">
                  {% if paper.published %}
                    {{ paper.published | readableDate }}
                  {% else %}
                    Recent
                  {% endif %}
                </span> • 
                <span class="authors">
                  {% if paper.authors and paper.authors.length > 0 %}
                    {{ paper.authors | join(', ') }}
                  {% else %}
                    Unknown authors
                  {% endif %}
                </span>
              </div>
              <p class="paper-summary text-sm">
                {% if paper.summary %}
                  {{ paper.summary | truncate(200) }}
                {% else %}
                  No summary available
                {% endif %}
              </p>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="no-papers">
          <p>No recent papers found. Papers will appear after the next build.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>