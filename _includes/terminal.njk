<div class="terminal-box">
  <div class="terminal-header">{{ site.homepage.terminal_prompt }}</div>
  <div class="terminal-content">
    {% if homeCommands %}
      {% for cmd in homeCommands %}
        <div class="command-line">
          <span class="prompt">$</span>
          <span class="command">{{ cmd.command }}</span>
        </div>
        <div class="response">
          {% if cmd.type == 'text' %}
            <p>{{ cmd.response }}</p>
          {% elif cmd.type == 'list' %}
            <ul>
              {% for item in cmd.response %}
                <li>{{ item }}</li>
              {% endfor %}
            </ul>
          {% elif cmd.type == 'html' %}
            {{ cmd.response | safe }}
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      <div class="command-line">
        <span class="prompt">$</span>
        <span class="command">echo "Terminal ready"</span>
      </div>
      <div class="response">
        <p>Terminal ready</p>
      </div>
    {% endif %}
  </div>
</div>