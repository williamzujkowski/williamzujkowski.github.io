<div class="terminal-box">
  <div class="terminal-header">{{ site.homepage.terminal_prompt }}</div>
  <div class="terminal-content">
    {% if homeCommands %}
      {% for cmd in homeCommands %}
        <div class="command-line">
          <span class="prompt">❯</span>
          <span class="command">{{ cmd.command }}</span>
        </div>
        <div class="response">
          {% if cmd.type == 'text' %}
            <p class="terminal-paragraph">{{ cmd.response }}</p>
          {% elif cmd.type == 'list' %}
            <ul class="terminal-list">
              {% for item in cmd.response %}
                <li class="terminal-list-item">{{ item }}</li>
              {% endfor %}
            </ul>
          {% elif cmd.type == 'html' %}
            <div class="terminal-html">{{ cmd.response | safe }}</div>
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      <div class="command-line">
        <span class="prompt">❯</span>
        <span class="command">echo "Terminal ready"</span>
      </div>
      <div class="response">
        <p class="terminal-paragraph">Terminal ready</p>
      </div>
    {% endif %}
  </div>
</div>