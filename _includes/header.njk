<header class="site-header">
  <div class="site-title">
    <a href="/">{{ site.title }}</a>
  </div>
  <div class="header-right">
    <nav class="site-nav">
      <ul>
        {% for item in site.navigation %}
          <li>
            <a
              href="{{ item.url }}"
              class="nav-item"
              {% if page.url == item.url %}aria-current="page"{% endif %}
              >{{ item.icon | safe }} {{ item.name }}</a
            >
          </li>
        {% endfor %}
      </ul>
    </nav>
    <div class="header-social">
      {% for social in site.social_media %}
        {% if social.display_in_header and social.enabled %}
          <a
            href="{{ social.url }}"
            class="header-social-link"
            aria-label="{{ social.name }}"
            title="{{ social.name }}"
          >{{ social.icon | safe }}</a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</header>
