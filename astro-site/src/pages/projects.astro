---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const featured = projects.filter((p) => p.data.featured);
const other = projects.filter((p) => !p.data.featured);

const categoryLabels: Record<string, string> = {
  ai: 'AI & ML',
  security: 'Security',
  infrastructure: 'Infrastructure',
  tools: 'Dev Tools',
};
---

<BaseLayout
  title="Projects"
  description="Open source projects and tools — AI orchestration, security engineering, and homelab infrastructure."
>
  <div class="prose">
    <h1>Projects</h1>
    <p>
      Open source tools and experiments in AI orchestration, security engineering, and infrastructure.
    </p>
  </div>

  {featured.length > 0 && (
    <div class="project-section">
      <h2 class="section-label">Featured</h2>
      {featured.map((project) => (
        <a href={project.data.url} class="project-item" rel="noopener noreferrer" target="_blank">
          <div class="project-header">
            <h3>{project.data.title}</h3>
            <span class="project-status">{project.data.status}</span>
          </div>
          <p class="project-desc">{project.data.description}</p>
          <div class="project-meta">
            <span>{categoryLabels[project.data.category] ?? project.data.category}</span>
            {project.data.tags.slice(0, 4).map((tag: string) => (
              <span>{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  )}

  {other.length > 0 && (
    <div class="project-section">
      <h2 class="section-label">More Projects</h2>
      {other.map((project) => (
        <a href={project.data.url} class="project-item" rel="noopener noreferrer" target="_blank">
          <div class="project-header">
            <h3>{project.data.title}</h3>
            <span class="project-status">{project.data.status}</span>
          </div>
          <p class="project-desc">{project.data.description}</p>
        </a>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  /* Remarque Project Dossier — list layout, no card grids */
  .project-section {
    max-width: var(--content-reading);
    margin-inline: auto;
    margin-block-start: var(--space-7);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 400;
    margin-block-end: var(--space-4);
    padding-block-end: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .project-item {
    display: block;
    text-decoration: none;
    color: var(--color-fg);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--motion-fast) var(--motion-easing);
  }

  .project-item:hover { color: var(--color-accent); }
  .project-item:hover h3 { color: var(--color-accent); }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
  }

  .project-header h3 {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-title);
    margin: 0;
    transition: color var(--motion-fast) var(--motion-easing);
  }

  .project-status {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-muted);
    letter-spacing: var(--tracking-meta);
    white-space: nowrap;
  }

  .project-desc {
    font-size: var(--text-body);
    color: var(--color-fg-muted);
    margin-block-start: var(--space-1);
    margin-block-end: 0;
    line-height: var(--leading-body);
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-block-start: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-muted);
    letter-spacing: var(--tracking-meta);
  }
</style>
