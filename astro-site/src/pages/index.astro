---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/lib/siteConfig';
import { getCollection } from 'astro:content';
import PostCard from '@components/PostCard.astro';
import headshot from '@/assets/images/headshot.png';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
      <div
        class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[var(--md-sys-color-primary)] to-[oklch(0.65_0.25_300)] opacity-15 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"
      >
      </div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 lg:py-40">
      <div class="mx-auto max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class="text-center lg:text-left">
            <h1
              class="text-4xl font-bold tracking-tight sm:text-6xl animate-fade-in-up"
              style="font-size: var(--md-sys-typescale-display-large)"
            >
              Hi, I'm <span class="gradient-text">William Zujkowski</span>
            </h1>
            <p
              class="mt-6 text-lg leading-8 text-[var(--md-sys-color-on-surface-variant)] animate-fade-in-up animation-delay-200"
            >
              Senior Information Security Engineer with 15+ years securing federal platforms. When I'm not designing
              cloud security controls, I'm in my homelab breaking things on purpose to understand how they work. Here,
              I share what works, what fails, and the lessons I've learned since 2005.
            </p>
            <div
              class="mt-10 flex items-center justify-center lg:justify-start gap-4 animate-fade-in-up animation-delay-400"
            >
              <a href="/about/" class="btn-filled">Learn more about me</a>
              <a href="/posts/" class="btn-outlined">
                Read my posts <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
          <div
            class="flex justify-center lg:justify-end animate-fade-in-up animation-delay-200 order-first lg:order-last"
          >
            <Image
              src={headshot}
              alt="William Zujkowski"
              width={320}
              height={320}
              class="w-48 h-48 sm:w-64 sm:h-64 lg:w-80 lg:h-80 rounded-full shadow-2xl ring-4 ring-[var(--md-sys-color-primary-container)]"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="py-12 bg-[var(--md-sys-color-surface-container-low)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <blockquote class="text-xl italic font-medium">
          "A robot may not harm humanity, or, by inaction, allow humanity to come to harm."
          <footer class="mt-2 text-base not-italic font-normal text-[var(--md-sys-color-on-surface-variant)]">
            — Isaac Asimov, The Zeroth Law
          </footer>
        </blockquote>
        <p class="mt-6 text-lg text-[var(--md-sys-color-on-surface-variant)]">
          That nerdy kid in 1995 devouring <em>Foundation and Empire</em> under the covers with a flashlight? Yeah, that was
          me. Now I'm helping secure FedRAMP platforms while running local LLMs on my RTX 3090 to explore AI security.
          I'm implementing the actual controls to keep AI systems safe — thinking about the same questions Asimov posed, just
          with more YAML files, threat models, and security tooling than I expected.
        </p>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section class="py-16 sm:py-24 bg-[var(--md-sys-color-surface-container-low)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2
          class="text-3xl font-bold tracking-tight sm:text-4xl"
          style="font-size: var(--md-sys-typescale-headline-large)"
        >
          What I Do
        </h2>
        <p class="mt-2 text-lg text-[var(--md-sys-color-on-surface-variant)]">Areas of expertise and interests</p>
      </div>

      <div class="mx-auto mt-12 max-w-none grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-4">
        {
          [
            {
              title: 'Security Engineering',
              href: '/tags/security/',
              icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
              description:
                "Implementing Zero-Trust architectures for federal systems. Microsegmentation isn't just theory – it's what stops lateral movement when something gets through.",
            },
            {
              title: 'Homelab & Automation',
              href: '/tags/homelab/',
              icon: 'M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 01-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z',
              description:
                "Started with a $50 Raspberry Pi in 2015, now running enterprise gear in my basement. Every failure in my homelab is a lesson I don't have to learn the hard way anywhere else.",
            },
            {
              title: 'AI & Security',
              href: '/tags/ai/',
              icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z',
              description:
                "Running local LLMs for security research and AI safety experiments. That childhood obsession with Asimov's Three Laws evolved into real work on AI alignment.",
            },
            {
              title: 'Knowledge Sharing',
              href: '/posts/',
              icon: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25',
              description: `${allPosts.length}+ posts on security, AI safety, and homelab experiments — practical lessons from real projects, not just theory.`,
            },
          ].map((feature) => (
            <a href={feature.href} class="card group p-6 flex flex-col no-underline hover:no-underline">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--md-sys-color-primary)] group-hover:scale-110 transition-transform">
                <svg
                  class="h-6 w-6 text-[var(--md-sys-color-on-primary)]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
                </svg>
              </div>
              <h3 class="text-base font-semibold">{feature.title}</h3>
              <p class="mt-2 text-sm text-[var(--md-sys-color-on-surface-variant)] flex-grow">{feature.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2
          class="text-3xl font-bold tracking-tight sm:text-4xl"
          style="font-size: var(--md-sys-typescale-headline-large)"
        >
          Recent Posts
        </h2>
        <p class="mt-2 text-lg text-[var(--md-sys-color-on-surface-variant)]">
          Security insights, AI experiments, homelab adventures, and lessons from the field.
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-8 md:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {recentPosts.map((post) => <PostCard post={post} variant="vertical" maxTags={3} />)}
      </div>

      {
        allPosts.length > 3 && (
          <div class="mt-12 text-center">
            <a href="/posts/" class="btn-filled">
              View all posts
            </a>
          </div>
        )
      }
    </div>
  </section>

  <!-- Featured Projects -->
  {
    featuredProjects.length > 0 && (
      <section class="py-16 sm:py-24">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-2xl text-center">
            <h2
              class="text-3xl font-bold tracking-tight sm:text-4xl"
              style="font-size: var(--md-sys-typescale-headline-large)"
            >
              Open Source Projects
            </h2>
            <p class="mt-2 text-lg text-[var(--md-sys-color-on-surface-variant)]">
              Tools I'm building and maintaining.
            </p>
          </div>

          <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-8 md:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
            {featuredProjects.map((project) => (
              <a
                href={project.data.url}
                class="card group p-6 flex flex-col no-underline hover:no-underline"
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="flex items-center gap-2 mb-3">
                  <span class="chip text-xs">
                    {project.data.category === 'ai'
                      ? 'AI & Machine Learning'
                      : project.data.category === 'security'
                        ? 'Security'
                        : project.data.category === 'tools'
                          ? 'Developer Tools'
                          : 'Infrastructure'}
                  </span>
                  <span class="text-xs text-[var(--md-sys-color-on-surface-variant)]">{project.data.status}</span>
                </div>
                <h3 class="text-lg font-semibold group-hover:text-[var(--md-sys-color-primary)] transition-colors">
                  {project.data.title}
                </h3>
                <p class="mt-2 text-sm text-[var(--md-sys-color-on-surface-variant)] flex-grow">
                  {project.data.description}
                </p>
                <div class="mt-4 flex flex-wrap gap-1">
                  {project.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--md-sys-color-surface-container-high)] text-[var(--md-sys-color-on-surface-variant)]">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            ))}
          </div>

          <div class="mt-12 text-center">
            <a href="/projects/" class="btn-outlined">View all projects</a>
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="card px-6 py-16 sm:px-12 sm:py-20 lg:px-16 text-center"
        style="border-radius: var(--md-sys-shape-corner-extra-large)"
      >
        <h2
          class="text-3xl font-bold tracking-tight sm:text-4xl"
          style="font-size: var(--md-sys-typescale-headline-large)"
        >
          Let's Connect
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg text-[var(--md-sys-color-on-surface-variant)]">
          Got a security question? Building your first homelab? Debating if that CVSS 7.2 vulnerability is worth an
          emergency patch at 10 PM? Let's chat.
        </p>
        <div class="mt-10 flex items-center justify-center gap-4">
          <a href="/about/#contact" class="btn-filled">Get in touch</a>
          <a href={SITE_CONFIG.social.github} class="btn-outlined" target="_blank" rel="noopener noreferrer">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
