---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getImageUrl, getReadingTime } from '@/lib/utils';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
      <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[var(--md-sys-color-primary)] to-[oklch(0.65_0.25_300)] opacity-15 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 lg:py-40">
      <div class="mx-auto max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class="text-center lg:text-left">
            <h1 class="text-4xl font-bold tracking-tight sm:text-6xl animate-fade-in-up" style="font-size: var(--md-sys-typescale-display-large)">
              Hi, I'm <span class="gradient-text">William Zujkowski</span>
            </h1>
            <p class="mt-6 text-lg leading-8 text-[var(--md-sys-color-on-surface-variant)] animate-fade-in-up animation-delay-200">
              Senior Information Security Engineer with 15+ years securing federal platforms. I spent last Saturday at 2 AM
              debugging a K3s cluster in my homelab – and loved every minute of it. Here, I share what works,
              what spectacularly fails, and the lessons I've learned from breaking things (legally, of course)
              since 2010.
            </p>
            <div class="mt-10 flex items-center justify-center lg:justify-start gap-4 animate-fade-in-up animation-delay-400">
              <a href="/about/" class="btn-filled">Learn more about me</a>
              <a href="/posts/" class="btn-outlined">
                Read my posts <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
          <div class="flex justify-center lg:justify-end animate-fade-in-up animation-delay-200 order-first lg:order-last">
            <img
              src="/assets/images/headshot.png"
              alt="William Zujkowski"
              class="w-48 h-48 sm:w-64 sm:h-64 lg:w-80 lg:h-80 rounded-full shadow-2xl ring-4 ring-[var(--md-sys-color-primary-container)]"
              loading="eager"
              width="320"
              height="320"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="py-12 bg-[var(--md-sys-color-surface-container-low)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <blockquote class="text-xl italic font-medium">
          "A robot may not harm humanity, or, by inaction, allow humanity to come to harm."
          <footer class="mt-2 text-base not-italic font-normal text-[var(--md-sys-color-on-surface-variant)]">
            — Isaac Asimov, The Zeroth Law
          </footer>
        </blockquote>
        <p class="mt-6 text-lg text-[var(--md-sys-color-on-surface-variant)]">
          That nerdy kid in 1995 devouring <em>Foundation and Empire</em> under the covers with a flashlight?
          Yeah, that was me. Now I'm helping secure a FedRAMP Moderate platform while running local LLMs on my RTX 3090
          to explore AI security. I'm implementing the actual controls to keep AI systems safe – thinking about
          the same questions Asimov posed, just with more YAML files, threat models, and 3 AM security patches
          than I expected.
        </p>
      </div>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" style="font-size: var(--md-sys-typescale-headline-large)">
          Recent Posts
        </h2>
        <p class="mt-2 text-lg text-[var(--md-sys-color-on-surface-variant)]">
          Security insights, AI experiments, homelab adventures, and lessons from the field.
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-8 md:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {recentPosts.map((post) => (
          <article class="card group relative p-6 flex flex-col">
            {getImageUrl(post.data.image) && (
              <div class="mb-4 -mx-6 -mt-6 overflow-hidden rounded-t-[var(--md-sys-shape-corner-large)]">
                <img src={getImageUrl(post.data.image)} alt={post.data.title} class="w-full h-40 object-cover" loading="lazy" />
              </div>
            )}
            <div class="flex items-center gap-3 text-sm">
              <time datetime={post.data.date.toISOString().split('T')[0]} class="font-medium text-[var(--md-sys-color-primary)]">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="text-[var(--md-sys-color-outline)]">&middot;</span>
              <span class="text-[var(--md-sys-color-on-surface-variant)]">
                {getReadingTime(post.body ?? '')} min read
              </span>
            </div>
            <h3 class="mt-3 text-lg font-semibold leading-snug group-hover:text-[var(--md-sys-color-primary)]">
              <a href={`/posts/${post.id}/`}>
                <span class="absolute inset-0"></span>
                {post.data.title}
              </a>
            </h3>
            <p class="mt-3 text-sm text-[var(--md-sys-color-on-surface-variant)] line-clamp-3 flex-grow">
              {post.data.description}
            </p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {post.data.tags.filter((t: string) => t !== 'posts').slice(0, 3).map((tag: string) => (
                  <span class="chip text-xs">{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>

      {allPosts.length > 3 && (
        <div class="mt-12 text-center">
          <a href="/posts/" class="btn-filled">View all posts</a>
        </div>
      )}
    </div>
  </section>

  <!-- What I Do -->
  <section class="py-16 sm:py-24 bg-[var(--md-sys-color-surface-container-low)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" style="font-size: var(--md-sys-typescale-headline-large)">
          What I Do
        </h2>
        <p class="mt-2 text-lg text-[var(--md-sys-color-on-surface-variant)]">
          Areas of expertise and interests
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-none grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-4">
        {[
          {
            title: 'Security Engineering',
            href: '/tags/security/',
            icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
            description: "Implementing Zero-Trust architectures for federal systems. Microsegmentation isn't just theory – it's what stops lateral movement when something gets through.",
          },
          {
            title: 'Homelab & Automation',
            href: '/tags/homelab/',
            icon: 'M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 01-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z',
            description: "Started with a $50 Raspberry Pi in 2015, now running enterprise gear in my basement. I've broken it 47 times and learned something valuable every single time.",
          },
          {
            title: 'AI & Security',
            href: '/tags/ai/',
            icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z',
            description: "Running local LLMs for security research and AI safety experiments. That childhood obsession with Asimov's Three Laws evolved into real work on AI alignment.",
          },
          {
            title: 'Knowledge Sharing',
            href: '/posts/',
            icon: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25',
            description: `Writing ${allPosts.length}+ blog posts about security, AI safety, and homelab experiments. My most popular posts openly admit "here's what I broke and what I learned."`,
          },
        ].map((feature) => (
          <a href={feature.href} class="card group p-6 flex flex-col no-underline hover:no-underline">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--md-sys-color-primary)] group-hover:scale-110 transition-transform">
              <svg class="h-6 w-6 text-[var(--md-sys-color-on-primary)]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="text-base font-semibold">{feature.title}</h3>
            <p class="mt-2 text-sm text-[var(--md-sys-color-on-surface-variant)] flex-grow">{feature.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="card px-6 py-16 sm:px-12 sm:py-20 lg:px-16 text-center" style="border-radius: var(--md-sys-shape-corner-extra-large)">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" style="font-size: var(--md-sys-typescale-headline-large)">
          Let's Connect
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg text-[var(--md-sys-color-on-surface-variant)]">
          Got a security question? Building your first homelab? Debating if that CVSS 7.2 vulnerability
          is worth an emergency patch at 10 PM? Let's chat.
        </p>
        <div class="mt-10 flex items-center justify-center gap-4">
          <a href="/about/#contact" class="btn-filled">Get in touch</a>
          <a href="https://github.com/williamzujkowski" class="btn-outlined">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
