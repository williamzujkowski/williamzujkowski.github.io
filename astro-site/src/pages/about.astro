---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/lib/siteConfig';
---

<BaseLayout title="About" description="About William Zujkowski — security architecture, identity, and compliance.">
  <section class="py-12 sm:py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <!-- Intro -->
        <div class="max-w-3xl mx-auto prose prose-lg">
          <h1>About William Zujkowski</h1>
          <p class="lead text-xl italic" style="color: var(--md-sys-color-on-surface-variant);">
            I'm a Senior InfoSec Engineer at <a href="https://cloud.gov" target="_blank" rel="noopener noreferrer">Cloud.gov</a> focused on cloud platform security, identity federation, and compliance
            automation. I spend my days designing security controls that enable teams instead of blocking them. I also
            spend way too many nights in my homelab breaking things to understand how they work.
          </p>
          <p>
            My work centers on designing security controls for multi-tenant cloud platforms&mdash;network segmentation,
            identity federation, compliance automation, and CI/CD security tooling. The goal: make the secure path the
            easy path so teams can deploy safely without fighting security controls.
          </p>
        </div>

        <hr class="my-12 border-[var(--md-sys-color-outline-variant)]" />

        <!-- The Journey -->
        <section class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-bold mb-8" style="color: var(--md-sys-color-on-surface);">The Journey</h2>
          <p class="mb-10 text-base" style="color: var(--md-sys-color-on-surface-variant);">
            20 years of breaking things and learning how to fix them&mdash;from house calls in Harrisburg to helping
            secure a federal cloud platform.
          </p>

          <!-- Vertical Timeline -->
          <div class="relative ml-4 sm:ml-0">
            <!-- Timeline line -->
            <div
              class="absolute left-4 sm:left-6 top-0 bottom-0 w-0.5"
              style="background: linear-gradient(to bottom, var(--md-sys-color-primary), var(--md-sys-color-outline-variant));"
            ></div>

            <!-- Cloud.gov — Present -->
            <div class="relative pl-14 sm:pl-16 pb-12">
              <div
                class="absolute left-2 sm:left-4 top-1 w-5 h-5 rounded-full border-3 z-10"
                style="background-color: var(--md-sys-color-primary); border-color: var(--md-sys-color-primary-container); box-shadow: 0 0 0 4px var(--md-sys-color-surface), 0 0 12px var(--md-sys-color-primary);"
              ></div>
              <div class="card p-5 sm:p-6" style="border-left: 3px solid var(--md-sys-color-primary);">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span
                    class="inline-block px-2.5 py-0.5 rounded-full text-xs font-bold"
                    style="background-color: var(--md-sys-color-primary); color: var(--md-sys-color-on-primary);"
                  >2023 &ndash; Present</span>
                  <span class="text-xs font-medium" style="color: var(--md-sys-color-primary);">&#9679; Current Role</span>
                </div>
                <h3 class="text-lg font-bold mb-1" style="color: var(--md-sys-color-on-surface);">
                  Senior InfoSec Engineer &bull;
                  <a href="https://cloud.gov" target="_blank" rel="noopener noreferrer" class="hover:underline" style="color: var(--md-sys-color-primary);">Cloud.gov</a>
                </h3>
                <p class="text-sm" style="color: var(--md-sys-color-on-surface-variant);">
                  Shaping cloud security architecture and federal compliance posture for a FedRAMP Moderate platform.
                  Contributing to the NIST 800-53 Rev 4 &rarr; Rev 5 transition and participating in FedRAMP RFCs.
                  All those years of breaking things turned out to be decent preparation.
                </p>
              </div>
            </div>

            <!-- HPC SRE — 2023 -->
            <div class="relative pl-14 sm:pl-16 pb-12">
              <div
                class="absolute left-2 sm:left-4 top-1 w-5 h-5 rounded-full border-2 z-10"
                style="background-color: var(--md-sys-color-surface); border-color: var(--md-sys-color-secondary);"
              ></div>
              <div class="card p-5 sm:p-6" style="border-left: 3px solid var(--md-sys-color-secondary);">
                <span
                  class="inline-block px-2.5 py-0.5 rounded-full text-xs font-bold mb-2"
                  style="background-color: var(--md-sys-color-secondary-container); color: var(--md-sys-color-on-secondary-container);"
                >2023</span>
                <h3 class="text-lg font-bold mb-1" style="color: var(--md-sys-color-on-surface);">
                  Lead HPC Site Reliability Engineer
                </h3>
                <p class="text-sm" style="color: var(--md-sys-color-on-surface-variant);">
                  Supporting high-performance computing clusters for molecular dynamics and computational biology
                  research. Got to burn in 8-way H100 nodes and help configure NVLink&mdash;genuinely fun work.
                  Learned that uptime matters just as much as security when researchers are running week-long
                  simulations that cost thousands in compute time.
                </p>
              </div>
            </div>

            <!-- NIH OCIO VM Lead — 2021-2023 -->
            <div class="relative pl-14 sm:pl-16 pb-12">
              <div
                class="absolute left-2 sm:left-4 top-1 w-5 h-5 rounded-full border-2 z-10"
                style="background-color: var(--md-sys-color-surface); border-color: var(--md-sys-color-tertiary, var(--md-sys-color-secondary));"
              ></div>
              <div class="card p-5 sm:p-6" style="border-left: 3px solid var(--md-sys-color-tertiary, var(--md-sys-color-secondary));">
                <span
                  class="inline-block px-2.5 py-0.5 rounded-full text-xs font-bold mb-2"
                  style="background-color: var(--md-sys-color-tertiary-container, var(--md-sys-color-secondary-container)); color: var(--md-sys-color-on-tertiary-container, var(--md-sys-color-on-secondary-container));"
                >2021 &ndash; 2023</span>
                <h3 class="text-lg font-bold mb-1" style="color: var(--md-sys-color-on-surface);">
                  Enterprise Vulnerability Management Lead &bull; NIH&nbsp;OCIO
                </h3>
                <p class="text-sm mb-3" style="color: var(--md-sys-color-on-surface-variant);">
                  Led vulnerability management across <strong>100,000+ assets</strong> and <strong>27 Institutes and
                  Centers</strong>. The hardest part wasn't the tech&mdash;it was convincing 27 different IT teams to
                  move at the same speed.
                </p>
                <div class="flex flex-wrap gap-2">
                  <span
                    class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs"
                    style="background-color: var(--md-sys-color-tertiary-container, var(--md-sys-color-secondary-container)); color: var(--md-sys-color-on-tertiary-container, var(--md-sys-color-on-secondary-container));"
                  >&#x1F525; Log4j SME</span>
                  <span
                    class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs"
                    style="background-color: var(--md-sys-color-tertiary-container, var(--md-sys-color-secondary-container)); color: var(--md-sys-color-on-tertiary-container, var(--md-sys-color-on-secondary-container));"
                  >&#x1F3DB; CISA BOD 22-01</span>
                </div>
              </div>
            </div>

            <!-- NHGRI — 2018-2021 -->
            <div class="relative pl-14 sm:pl-16 pb-12">
              <div
                class="absolute left-2 sm:left-4 top-1 w-5 h-5 rounded-full border-2 z-10"
                style="background-color: var(--md-sys-color-surface); border-color: var(--md-sys-color-tertiary, var(--md-sys-color-secondary));"
              ></div>
              <div class="card p-5 sm:p-6" style="border-left: 3px solid var(--md-sys-color-tertiary, var(--md-sys-color-secondary));">
                <span
                  class="inline-block px-2.5 py-0.5 rounded-full text-xs font-bold mb-2"
                  style="background-color: var(--md-sys-color-tertiary-container, var(--md-sys-color-secondary-container)); color: var(--md-sys-color-on-tertiary-container, var(--md-sys-color-on-secondary-container));"
                >2018 &ndash; 2021</span>
                <h3 class="text-lg font-bold mb-1" style="color: var(--md-sys-color-on-surface);">
                  Security Engineering Lead &bull; NHGRI
                </h3>
                <p class="text-sm" style="color: var(--md-sys-color-on-surface-variant);">
                  Securing research infrastructure for about <strong>2,200 endpoints</strong>&mdash;including
                  million-dollar genomic sequencers that scientists would absolutely revolt over if you tried to patch
                  them during a sequencing run. Taught me more about stakeholder management than any textbook ever could.
                </p>
              </div>
            </div>

            <!-- NIH Entry — 2017 -->
            <div class="relative pl-14 sm:pl-16 pb-12">
              <div
                class="absolute left-2 sm:left-4 top-1 w-5 h-5 rounded-full border-2 z-10"
                style="background-color: var(--md-sys-color-surface); border-color: var(--md-sys-color-outline);"
              ></div>
              <div class="card p-5 sm:p-6" style="border-left: 3px solid var(--md-sys-color-outline);">
                <span
                  class="inline-block px-2.5 py-0.5 rounded-full text-xs font-bold mb-2"
                  style="background-color: var(--md-sys-color-surface-container-highest); color: var(--md-sys-color-on-surface);"
                >2014 &ndash; 2017</span>
                <h3 class="text-lg font-bold mb-1" style="color: var(--md-sys-color-on-surface);">
                  IT Infrastructure &amp; Service Desk Leadership
                </h3>
                <p class="text-sm" style="color: var(--md-sys-color-on-surface-variant);">
                  Moved through several IT infrastructure and support roles&mdash;from asset management to leading
                  service desk teams in the NIH ecosystem. Gravitating toward the security engineering work that would
                  define the next chapter.
                </p>
              </div>
            </div>

            <!-- Independent Consulting — 2005-2014 -->
            <div class="relative pl-14 sm:pl-16 pb-4">
              <div
                class="absolute left-2 sm:left-4 top-1 w-5 h-5 rounded-full border-2 z-10"
                style="background-color: var(--md-sys-color-surface); border-color: var(--md-sys-color-outline-variant);"
              ></div>
              <div class="card p-5 sm:p-6" style="border-left: 3px solid var(--md-sys-color-outline-variant);">
                <span
                  class="inline-block px-2.5 py-0.5 rounded-full text-xs font-bold mb-2"
                  style="background-color: var(--md-sys-color-surface-container-high); color: var(--md-sys-color-on-surface-variant);"
                >2005 &ndash; 2014</span>
                <h3 class="text-lg font-bold mb-1" style="color: var(--md-sys-color-on-surface);">
                  Independent IT Consultant &bull; Harrisburg, PA
                </h3>
                <p class="text-sm" style="color: var(--md-sys-color-on-surface-variant);">
                  Nearly a decade of fixing broken computers and networks for anyone who'd hire me&mdash;small
                  businesses, local offices, whoever could pay my hourly rate. Evolved from "my computer won't start"
                  house calls into small-business infrastructure management. To this day, when a bad CVE drops and
                  other teams have to scramble on emergency patches, I grab pastries from my local Spanish bakery as
                  a thank-you. Small gestures go a long way.
                </p>
              </div>
            </div>
          </div>
        </section>

        <hr class="my-12 border-[var(--md-sys-color-outline-variant)]" />

        <!-- How I Think About Security -->
        <section>
          <h2 class="text-2xl font-bold mb-6" style="color: var(--md-sys-color-on-surface);">
            How I Think About Security
          </h2>
          <div class="card p-8 sm:p-10 my-8" style="background-color: var(--md-sys-color-surface-container);">
            <p class="text-lg mb-6" style="color: var(--md-sys-color-on-surface-variant);">
              I believe security should <strong style="color: var(--md-sys-color-on-surface);"
                >enable work, not block it</strong
              >. The best controls? Users never notice them because they just work. Nobody cares about your perfect
              firewall rules if they can't deploy their app.
            </p>

            <p class="text-lg mb-6" style="color: var(--md-sys-color-on-surface-variant);">
              Here's what I've learned over 20 years in IT and 15 years in security:
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
              <div class="p-6 rounded-xl" style="background-color: var(--md-sys-color-surface-container-low);">
                <h3 class="font-semibold mb-3 flex items-center" style="color: var(--md-sys-color-on-surface);">
                  <span class="mr-2" aria-hidden="true">&#x26A1;</span>
                  Technical Excellence Is Not Enough
                </h3>
                <p class="text-sm" style="color: var(--md-sys-color-on-surface-variant);">
                  You can design the most elegant network segmentation in the world, but if developers can't deploy
                  their code, they'll find a workaround. Your job is to make the secure path the easy path. I learned
                  this the hard way trying to enforce patching schedules on scientists running week-long experiments.
                </p>
              </div>

              <div class="p-6 rounded-xl" style="background-color: var(--md-sys-color-surface-container-low);">
                <h3 class="font-semibold mb-3 flex items-center" style="color: var(--md-sys-color-on-surface);">
                  <span class="mr-2" aria-hidden="true">&#x2699;</span>
                  Automation Isn't About Replacing People
                </h3>
                <p class="text-sm" style="color: var(--md-sys-color-on-surface-variant);">
                  It's about freeing them to do interesting work instead of clicking buttons. I spent months learning
                  Terraform so teams I worked with could manage firewall rules as code instead of logging into
                  consoles. Best investment I've made. Now the time goes to architecture problems, not typos.
                </p>
              </div>

              <div class="p-6 rounded-xl" style="background-color: var(--md-sys-color-surface-container-low);">
                <h3 class="font-semibold mb-3 flex items-center" style="color: var(--md-sys-color-on-surface);">
                  <span class="mr-2" aria-hidden="true">&#x1F4A1;</span>
                  AI Security Is About Governance, Not Just Tech
                </h3>
                <p class="text-sm" style="color: var(--md-sys-color-on-surface-variant);">
                  I'm exploring how we build and secure AI systems that augment human decision-making rather than
                  replace it. The hard problems aren't the models&mdash;they're the humans, policies, and processes
                  around them. Just like every other security problem I've worked on.
                </p>
              </div>
            </div>

            <p class="text-base italic" style="color: var(--md-sys-color-on-surface-variant);">
              If security slows teams down, they'll work around it. If compliance feels like busywork, it won't get done
              right. If automation is brittle, nobody will trust it. I've been doing this long enough to know: good
              security is invisible until you need it.
            </p>
          </div>
        </section>

        <hr class="my-12 border-[var(--md-sys-color-outline-variant)]" />

        <!-- When I'm Not Working -->
        <section>
          <h2 class="text-2xl font-bold mb-6" style="color: var(--md-sys-color-on-surface);">When I'm Not Working</h2>
          <div class="card p-8 my-8">
            <p class="text-lg mb-4" style="color: var(--md-sys-color-on-surface-variant);">
              You'll find me in my homelab, which has grown from a single Raspberry Pi in 2015 to a Dell PowerEdge R940
              running Proxmox, a fleet of Raspberry Pi 4s handling K3s clusters, and way too many Docker containers. I
              run my own Wazuh SIEM, self-hosted Bitwarden, and whatever else I'm experimenting with that week.
            </p>

            <p class="text-lg mb-4" style="color: var(--md-sys-color-on-surface-variant);">
              I'm also deep into AI/LLM experimentation&mdash;not just using ChatGPT, but actually running local models,
              building agents, and figuring out how to secure these systems in production environments. It's fascinating
              and humbling in equal measure. You can see what I'm building on the <a href="/projects" class="text-[var(--md-sys-color-primary)] hover:underline">projects page</a>.
            </p>

            <p class="text-lg mb-4" style="color: var(--md-sys-color-on-surface-variant);">
              <strong style="color: var(--md-sys-color-on-surface);">Fair warning:</strong> I've burned out a GPU
              pushing it too hard for local LLM inference. Also managed to take down my home network for a few hours
              trying to implement VLAN segmentation "just to see how it works." Breaking things in my homelab so I
              don't break them anywhere else is kind of the whole point.
            </p>

            <p class="text-lg mb-4" style="color: var(--md-sys-color-on-surface-variant);">
              I'm currently learning Rust by building a vulnerability aggregation tool that I'll probably never finish.
              But that's the point&mdash;curiosity is the best cybersecurity skill there is.
            </p>

            <p class="text-lg italic" style="color: var(--md-sys-color-on-surface-variant);">
              Favorite debugging method: rubber duck debugging&mdash;with an actual rubber duck, because sometimes
              being literal is funny. I've also been known to deploy a
              <a href="https://datatracker.ietf.org/doc/html/rfc2321" class="text-[var(--md-sys-color-primary)] hover:underline">RITA</a>
              (rubber chicken) for particularly stubborn bugs. The obnoxiously loud squeak really helps you
              rethink your assumptions.
            </p>
          </div>
        </section>

        <hr class="my-12 border-[var(--md-sys-color-outline-variant)]" />

        <!-- Connect -->
        <section>
          <h2 class="text-2xl font-bold mb-6" style="color: var(--md-sys-color-on-surface);">Connect</h2>
          <div class="card p-8 sm:p-10 my-8" style="background-color: var(--md-sys-color-surface-container);">
            <p class="text-xl mb-8 text-center leading-relaxed" style="color: var(--md-sys-color-on-surface-variant);">
              I love connecting with folks who geek out about cloud security, identity federation, compliance
              automation, or AI infrastructure security. Whether you're building something cool, stuck on a problem, or
              just want to talk shop about homelab setups, feel free to reach out.
            </p>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
              <div
                class="p-6 rounded-xl text-center transition-all duration-200 hover:scale-105"
                style="background-color: var(--md-sys-color-surface-container-low);"
              >
                <div
                  class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                  style="background-color: var(--md-sys-color-primary-container);"
                >
                  <span class="text-2xl" aria-hidden="true">&#x2601;</span>
                </div>
                <h3 class="text-sm font-bold mb-2" style="color: var(--md-sys-color-on-surface);">Cloud Security</h3>
                <p class="text-xs" style="color: var(--md-sys-color-on-surface-variant);">Architecture &amp; FedRAMP</p>
              </div>

              <div
                class="p-6 rounded-xl text-center transition-all duration-200 hover:scale-105"
                style="background-color: var(--md-sys-color-surface-container-low);"
              >
                <div
                  class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                  style="background-color: var(--md-sys-color-primary-container);"
                >
                  <span class="text-2xl" aria-hidden="true">&#x1F511;</span>
                </div>
                <h3 class="text-sm font-bold mb-2" style="color: var(--md-sys-color-on-surface);">
                  Identity &amp; Federation
                </h3>
                <p class="text-xs" style="color: var(--md-sys-color-on-surface-variant);">At Scale</p>
              </div>

              <div
                class="p-6 rounded-xl text-center transition-all duration-200 hover:scale-105"
                style="background-color: var(--md-sys-color-surface-container-low);"
              >
                <div
                  class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                  style="background-color: var(--md-sys-color-primary-container);"
                >
                  <span class="text-2xl" aria-hidden="true">&#x1F4CB;</span>
                </div>
                <h3 class="text-sm font-bold mb-2" style="color: var(--md-sys-color-on-surface);">Compliance</h3>
                <p class="text-xs" style="color: var(--md-sys-color-on-surface-variant);">NIST 800-53 Automation</p>
              </div>

              <div
                class="p-6 rounded-xl text-center transition-all duration-200 hover:scale-105"
                style="background-color: var(--md-sys-color-surface-container-low);"
              >
                <div
                  class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                  style="background-color: var(--md-sys-color-primary-container);"
                >
                  <span class="text-2xl" aria-hidden="true">&#x1F4A1;</span>
                </div>
                <h3 class="text-sm font-bold mb-2" style="color: var(--md-sys-color-on-surface);">AI Security</h3>
                <p class="text-xs" style="color: var(--md-sys-color-on-surface-variant);">
                  Infrastructure &amp; Governance
                </p>
              </div>
            </div>

            <div class="flex flex-wrap justify-center gap-4 sm:gap-6 mt-8">
              <a
                href={SITE_CONFIG.social.github}
                class="btn-filled px-8 py-4 text-base"
                style="background-color: var(--md-sys-color-inverse-surface); color: var(--md-sys-color-inverse-on-surface); min-height: 56px;"
                aria-label="Visit my GitHub profile"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="w-6 h-6 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                  ></path>
                </svg>
                <span class="font-medium">GitHub</span>
              </a>

              <a
                href={SITE_CONFIG.social.linkedin}
                class="btn-filled px-8 py-4 text-base"
                style="min-height: 56px;"
                aria-label="Visit my LinkedIn profile"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="w-6 h-6 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                  ></path>
                </svg>
                <span class="font-medium">LinkedIn</span>
              </a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
