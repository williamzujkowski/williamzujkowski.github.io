---
// Theme deck — reader-selectable terminal color schemes for the whole site.
// Powered by the curated subset of williamzujkowski/oklch-terminal-themes;
// token values are generated + contrast-validated by scripts/theme-deck/.
import themes from '@/data/theme-deck.json';

interface Props {
  variant?: 'footer' | 'header';
}
const { variant = 'footer' } = Astro.props;

const darkThemes = themes.filter((t) => t.isDark);
const lightThemes = themes.filter((t) => !t.isDark);
---

<details class={`theme-deck theme-deck--${variant}`} id="theme-deck">
  <summary aria-label="Terminal theme picker">
    {
      variant === 'header' ? (
        <span class="deck-mini" aria-hidden="true">
          {/* Live tokens, deliberately: the mini swatch previews the ACTIVE palette. */}
          <span class="deck-mini-chip" style="background: var(--color-accent)" />
          <span class="deck-mini-chip" style="background: var(--color-fg)" />
          <span class="deck-mini-chip" style="background: var(--color-bg-subtle)" />
        </span>
      ) : (
        <>
          <span class="deck-label">Terminal theme</span>
          <span class="deck-current" id="theme-deck-current">Remarque</span>
        </>
      )
    }
  </summary>

  <div class="deck-panel" role="radiogroup" aria-label="Site color theme">
    <button type="button" class="deck-option" role="radio" aria-checked="true" data-deck-slug="">
      {/* Literals, deliberately: this row depicts the Remarque palette itself,
          which must not repaint when another deck theme is active. */}
      <span class="deck-swatches" aria-hidden="true">
        <span class="deck-chip" style="background: oklch(0.95 0.015 75) /* allow-raw-color */"></span>
        <span class="deck-chip" style="background: oklch(0.48 0.15 140) /* allow-raw-color */"></span>
        <span class="deck-chip" style="background: oklch(0.55 0.14 75) /* allow-raw-color */"></span>
        <span class="deck-chip" style="background: oklch(0.18 0.04 25) /* allow-raw-color */"></span>
      </span>
      <span class="deck-name">Remarque <span class="deck-tag">default</span></span>
    </button>

    {
      [
        { group: 'Dark', list: darkThemes },
        { group: 'Light', list: lightThemes },
      ].map(({ group, list }) => (
        <>
          <p class="deck-group">{group}</p>
          {list.map((t) => (
            <button
              type="button"
              class="deck-option"
              role="radio"
              aria-checked="false"
              data-deck-slug={t.slug}
              data-deck-dark={t.isDark ? 'true' : 'false'}
              data-deck-name={t.name}
            >
              <span class="deck-swatches" aria-hidden="true">
                <span class="deck-chip" style={`background: ${t.swatches.bg}`} />
                {t.swatches.ansi.slice(1, 7).map((c) => (
                  <span class="deck-chip" style={`background: ${c}`} />
                ))}
                <span class="deck-chip" style={`background: ${t.swatches.fg}`} />
              </span>
              <span class="deck-name">{t.name}</span>
            </button>
          ))}
        </>
      ))
    }

    <p class="deck-credit">
      Palettes from <a href="https://github.com/williamzujkowski/oklch-terminal-themes">oklch&#8209;terminal&#8209;themes</a>
      (<a href="/about/#theme-credits">credits</a>)
    </p>
  </div>
</details>

<style>
  .theme-deck {
    font-family: var(--font-mono, monospace);
    font-size: var(--text-micro, 0.75rem);
    margin-top: 0.75rem;
  }

  .theme-deck summary {
    cursor: pointer;
    color: var(--color-muted);
    list-style: none;
    display: inline-flex;
    gap: 0.5ch;
    align-items: baseline;
    padding: 0.25rem 0;
  }
  .theme-deck summary::-webkit-details-marker { display: none; }
  .theme-deck summary::before { content: '❯ '; color: var(--color-accent); }
  .theme-deck[open] summary::before { content: '▾ '; }
  .theme-deck summary:hover .deck-label { color: var(--color-fg); }

  .deck-current { color: var(--color-accent); }

  .deck-panel {
    margin-top: 0.5rem;
    margin-inline: auto; /* footer centers text; center the panel box too */
    border: 1px solid var(--color-border);
    padding: 0.5rem;
    max-width: 22rem;
    background: var(--color-surface);
    text-align: left; /* ...but the rows themselves read left-to-right */
  }

  .deck-group {
    margin: 0.5rem 0 0.15rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .deck-option {
    display: flex;
    align-items: center;
    gap: 0.75ch;
    width: 100%;
    padding: 0.3rem 0.4rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-fg-muted);
    font: inherit;
    text-align: left;
  }
  .deck-option:hover { background: var(--color-bg-subtle); color: var(--color-fg); }
  .deck-option[aria-checked='true'] { color: var(--color-fg); }
  .deck-option[aria-checked='true'] .deck-name::after {
    content: ' ✓';
    color: var(--color-accent);
  }

  .deck-swatches { display: inline-flex; gap: 2px; flex: none; }
  .deck-chip {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 2px;
    border: 1px solid var(--color-border);
  }

  .deck-tag { color: var(--color-muted); }

  .deck-credit {
    margin: 0.6rem 0 0;
    color: var(--color-muted);
  }

  /* Header variant: compact swatch button, panel drops down right-aligned */
  .theme-deck--header {
    position: relative;
    margin-top: 0;
  }
  .theme-deck--header summary {
    padding: 0.35rem;
    width: 2.75rem; /* match the toggle's 44px touch target */
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.25rem;
  }
  .theme-deck--header summary::before,
  .theme-deck--header[open] summary::before {
    content: '';
  }
  .deck-mini {
    display: inline-flex;
    gap: 2px;
    transform: rotate(-6deg); /* a zine-appropriate tilt */
  }
  .deck-mini-chip {
    width: 0.55rem;
    height: 0.9rem;
    border-radius: 2px 1px 3px 1px / 1px 3px 1px 2px;
    border: 1px solid var(--color-border-bold);
  }
  .theme-deck--header .deck-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.4rem);
    width: min(22rem, calc(100vw - 2rem));
    max-height: min(70vh, 30rem);
    overflow-y: auto;
    background: var(--color-bg);
    z-index: 50;
    box-shadow: 0 4px 16px var(--color-shadow);
  }
</style>

<script is:inline>
  (function () {
    var DECK_KEY = 'themeDeck';

    // localStorage can throw (blocked cookies, some private modes) — the
    // picker must keep working without persistence.
    function storageGet(key) {
      try { return localStorage.getItem(key); } catch (e) { return null; }
    }
    function storageSet(key, value) {
      try { localStorage.setItem(key, value); } catch (e) { /* no persistence */ }
    }
    function storageRemove(key) {
      try { localStorage.removeItem(key); } catch (e) { /* no persistence */ }
    }

    function applyDeck(slug, isDark) {
      var root = document.documentElement;
      if (slug) {
        root.setAttribute('data-theme-deck', slug);
        // A deck theme is a complete palette: pin the base mode to match so
        // every mode-conditional style (icons, shiki, color-scheme) agrees.
        root.classList.remove('dark', 'light');
        root.classList.add(isDark ? 'dark' : 'light');
        // Value is "slug|mode" so the before-paint head script can restore
        // both without shipping any theme data.
        storageSet(DECK_KEY, slug + '|' + (isDark ? 'dark' : 'light'));
      } else {
        root.removeAttribute('data-theme-deck');
        storageRemove(DECK_KEY);
      }
      // Sync from the value just applied, not a storage round-trip — the UI
      // must match the DOM even when persistence is unavailable.
      syncUi(slug || '');
    }

    function syncUi(active) {
      if (active === undefined) {
        active = (storageGet(DECK_KEY) || '').split('|')[0];
      }
      var current = document.getElementById('theme-deck-current');
      var activeName = 'Remarque';
      document.querySelectorAll('.deck-option').forEach(function (btn) {
        var checked = (btn.getAttribute('data-deck-slug') || '') === active;
        btn.setAttribute('aria-checked', checked ? 'true' : 'false');
        // Roving tabindex per the ARIA radio-group pattern: one Tab stop.
        btn.setAttribute('tabindex', checked ? '0' : '-1');
        if (checked && btn.getAttribute('data-deck-name')) {
          activeName = btn.getAttribute('data-deck-name');
        }
      });
      if (current) current.textContent = activeName;
    }

    var options = Array.prototype.slice.call(document.querySelectorAll('.deck-option'));
    options.forEach(function (btn) {
      btn.addEventListener('click', function () {
        applyDeck(
          btn.getAttribute('data-deck-slug') || null,
          btn.getAttribute('data-deck-dark') === 'true'
        );
      });
    });

    var panel = document.querySelector('.deck-panel');
    if (panel) {
      panel.addEventListener('keydown', function (e) {
        var delta = { ArrowDown: 1, ArrowRight: 1, ArrowUp: -1, ArrowLeft: -1 }[e.key];
        if (!delta) return;
        var i = options.indexOf(document.activeElement);
        if (i === -1) return;
        e.preventDefault();
        var next = options[(i + delta + options.length) % options.length];
        next.focus();
        next.click(); // arrow moves selection, matching native radio behavior
      });
    }

    // Header popover manners: close on outside click or Escape.
    var deck = document.getElementById('theme-deck');
    if (deck) {
      document.addEventListener('click', function (e) {
        if (deck.open && !deck.contains(e.target)) deck.open = false;
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && deck.open) {
          deck.open = false;
          deck.querySelector('summary').focus();
        }
      });
    }

    document.addEventListener('theme-deck-cleared', function () { syncUi(); });
    syncUi();
  })();
</script>
