---
import { getCollection } from 'astro:content';

interface Props {
  currentId: string;
  series: string;
}

const { currentId, series } = Astro.props;

// Get all posts in this series, sorted by date (or seriesOrder if defined)
const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.series === series);
const sorted = allPosts.sort((a, b) => {
  // Prefer seriesOrder if both have it, otherwise sort by date
  if (a.data.seriesOrder !== undefined && b.data.seriesOrder !== undefined) {
    return a.data.seriesOrder - b.data.seriesOrder;
  }
  return a.data.date.getTime() - b.data.date.getTime();
});

const currentIndex = sorted.findIndex((p) => p.id === currentId);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const total = sorted.length;
const position = currentIndex + 1;
---

{
  total > 1 && (
    <nav
      class="my-8 p-5 rounded-[var(--md-sys-shape-corner-large)] border"
      style="background: var(--md-sys-color-surface-container); border-color: var(--md-sys-color-outline-variant);"
      aria-label={`${series} series navigation`}
    >
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium text-[var(--md-sys-color-primary)]">
          Series: {series}
        </span>
        <span class="text-xs text-[var(--md-sys-color-on-surface-variant)]">
          Part {position} of {total}
        </span>
      </div>

      {/* Progress bar */}
      <div
        class="h-1 rounded-full mb-4 overflow-hidden"
        style="background: var(--md-sys-color-surface-container-highest);"
      >
        <div
          class="h-full rounded-full"
          style={`width: ${(position / total) * 100}%; background: var(--md-sys-color-primary);`}
        />
      </div>

      {/* Posts list */}
      <ol class="space-y-1.5 mb-4">
        {sorted.map((post, i) => (
          <li class="text-sm">
            {post.id === currentId ? (
              <span class="font-medium text-[var(--md-sys-color-on-surface)]">
                {i + 1}. {post.data.title}
                <span class="text-xs text-[var(--md-sys-color-primary)] ml-1">(current)</span>
              </span>
            ) : (
              <a
                href={`/posts/${post.id}/`}
                class="text-[var(--md-sys-color-on-surface-variant)] hover:text-[var(--md-sys-color-primary)]"
              >
                {i + 1}. {post.data.title}
              </a>
            )}
          </li>
        ))}
      </ol>

      {/* Prev/Next navigation */}
      <div class="flex justify-between gap-4 pt-3 border-t" style="border-color: var(--md-sys-color-outline-variant);">
        {prev ? (
          <a
            href={`/posts/${prev.id}/`}
            class="text-sm text-[var(--md-sys-color-primary)] hover:underline"
          >
            &larr; Previous: {prev.data.title}
          </a>
        ) : (
          <span />
        )}
        {next ? (
          <a
            href={`/posts/${next.id}/`}
            class="text-sm text-[var(--md-sys-color-primary)] hover:underline text-right"
          >
            Next: {next.data.title} &rarr;
          </a>
        ) : (
          <span class="text-sm text-[var(--md-sys-color-on-surface-variant)] text-right italic">
            Series complete
          </span>
        )}
      </div>
    </nav>
  )
}
