---
import { getCollection } from 'astro:content';

interface Props {
  currentId: string;
  series: string;
}

const { currentId, series } = Astro.props;

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.series === series);
const sorted = allPosts.sort((a, b) => {
  if (a.data.seriesOrder !== undefined && b.data.seriesOrder !== undefined) {
    return a.data.seriesOrder - b.data.seriesOrder;
  }
  return a.data.date.getTime() - b.data.date.getTime();
});

const currentIndex = sorted.findIndex((p) => p.id === currentId);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const total = sorted.length;
const position = currentIndex + 1;
---

{
  total > 1 && (
    <nav
      class="series-nav"
      aria-label={`${series} series navigation`}
    >
      <div class="series-header">
        <span class="series-label">Series: {series}</span>
        <span class="series-position">Part {position} of {total}</span>
      </div>

      <div class="series-progress-track">
        <div class="series-progress-bar" style={`width: ${(position / total) * 100}%;`} />
      </div>

      <ol class="series-list">
        {sorted.map((post, i) => (
          <li>
            {post.id === currentId ? (
              <span class="series-current">
                {i + 1}. {post.data.title}
                <span class="series-current-label">(current)</span>
              </span>
            ) : (
              <a href={`/posts/${post.id}/`}>
                {i + 1}. {post.data.title}
              </a>
            )}
          </li>
        ))}
      </ol>

      <div class="series-nav-links">
        {prev ? (
          <a href={`/posts/${prev.id}/`}>
            &larr; Previous: {prev.data.title}
          </a>
        ) : (
          <span />
        )}
        {next ? (
          <a href={`/posts/${next.id}/`} class="series-next">
            Next: {next.data.title} &rarr;
          </a>
        ) : (
          <span class="series-complete">Series complete</span>
        )}
      </div>
    </nav>
  )
}

<style>
  .series-nav {
    margin-block: var(--space-6);
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .series-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-block-end: var(--space-3);
  }

  .series-label {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--color-accent);
    letter-spacing: var(--tracking-meta);
  }

  .series-position {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-muted);
  }

  .series-progress-track {
    height: 2px;
    background: var(--color-border);
    border-radius: 1px;
    margin-block-end: var(--space-4);
    overflow: hidden;
  }

  .series-progress-bar {
    height: 100%;
    background: var(--color-accent);
    border-radius: 1px;
  }

  .series-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4);
  }

  .series-list li {
    font-size: var(--text-meta);
    padding-block: var(--space-1);
  }

  .series-list a {
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color var(--motion-fast) var(--motion-easing);
  }

  .series-list a:hover { color: var(--color-accent); }

  .series-current {
    color: var(--color-fg);
    font-weight: var(--weight-medium);
  }

  .series-current-label {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    color: var(--color-accent);
    margin-left: var(--space-1);
  }

  .series-nav-links {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-meta);
  }

  .series-nav-links a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--motion-fast) var(--motion-easing);
  }

  .series-nav-links a:hover { text-decoration: underline; }

  .series-next { text-align: right; }

  .series-complete {
    color: var(--color-muted);
    font-style: italic;
    text-align: right;
  }
</style>
