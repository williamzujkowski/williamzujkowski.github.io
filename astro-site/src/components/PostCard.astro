---
import { getReadingTime } from '@/lib/utils';

interface Props {
  post: {
    id: string;
    body?: string | null;
    data: {
      title: string;
      date: Date;
      description?: string;
      tags?: string[];
      image?: string | { url?: string; src?: string };
    };
  };
  showTags?: boolean;
}

const { post, showTags = false } = Astro.props;

const readingTime = getReadingTime(post.body ?? '');
const tags = (post.data.tags ?? []).filter((t: string) => t !== 'posts');
const displayTags = tags.slice(0, 3);
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const isoDate = post.data.date.toISOString().split('T')[0];
---

<article class="post-card">
  <div class="post-card-meta">
    <time datetime={isoDate}>{formattedDate}</time>
    <span class="post-card-readtime">{readingTime} min read</span>
  </div>
  <div class="post-card-body">
    <a href={`/posts/${post.id}/`} class="post-card-title">
      {post.data.title}
    </a>
    {post.data.description && (
      <p class="post-card-excerpt">{post.data.description}</p>
    )}
    {showTags && displayTags.length > 0 && (
      <div class="chip-row">
        {displayTags.map((tag) => (
          <a href={`/tags/${tag}/`} class="chip">{tag}</a>
        ))}
      </div>
    )}
  </div>
</article>
