---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const filteredHeadings = headings.filter((h) => h.depth <= 3);
const showToc = filteredHeadings.length >= 3;
---

{
  showToc && (
    <nav aria-label="Table of contents" class="toc">
      <details>
        <summary>
          <span>On this page</span>
          <svg
            width="16"
            height="16"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
            class="toc-chevron"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <ul>
          {filteredHeadings.map((heading) => (
            <li style={`padding-left: ${(heading.depth - 2) * 1}rem`}>
              <a href={`#${heading.slug}`}>
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </details>
    </nav>
  )
}

<script is:inline>
  (function () {
    // Sticky side-rail mode (issue #274 item 4) — force the <details> open
    // at the >=1280px rail breakpoint so the list is actually visible.
    //
    // A CSS-only `details:not([open]) > ul { display: block }` override
    // was tried first and doesn't reliably win: modern Chromium renders
    // collapsed <details> content through an internal `::details-content`
    // box rather than a plain `display: none` on the child, so a plain
    // author-CSS override on the <ul> itself doesn't force it visible.
    // Toggling the real `open` attribute/property is the only path that's
    // guaranteed to work, so this is the actual mechanism now — not a
    // pure-CSS trick.
    //
    // Progressive enhancement: without JS the rail just shows a normal
    // collapsed, click-to-expand <details> — degraded but not broken.
    var details = document.querySelector('.toc details');
    if (!details || !window.matchMedia) return;
    var mq = window.matchMedia('(min-width: 1280px)');
    function sync(e) {
      details.open = e.matches;
    }
    sync(mq);
    mq.addEventListener('change', sync);
  })();
</script>

<style>
  /* Remarque TOC — borderless, mono, minimal */
  .toc {
    margin-block: var(--space-5);
  }

  .toc details summary {
    cursor: pointer;
    user-select: none;
    /* font-family: mono — shared machine-voice rule in global.css (#274) */
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-muted);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-2);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--motion-fast) var(--motion-easing);
  }

  .toc details summary:hover { color: var(--color-fg); }
  .toc details summary::-webkit-details-marker { display: none; }

  .toc-chevron {
    transition: transform var(--motion-normal) var(--motion-easing);
    flex-shrink: 0;
  }

  details[open] .toc-chevron { transform: rotate(180deg); }

  details[open] summary {
    margin-block-end: var(--space-3);
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li { margin-block-end: var(--space-1); }

  .toc a {
    /* font-family: mono — shared machine-voice rule in global.css (#274) */
    font-size: var(--text-meta);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color var(--motion-fast) var(--motion-easing);
  }

  .toc a:hover { color: var(--color-fg); }

  /* Sticky side-rail mode (issue #274 item 4) — the grid/sticky placement
     itself lives in global.css (`article.post-article > nav.toc`, needs
     `article` in scope); this block only adjusts the TOC's own
     presentation to suit a rail instead of an inline collapsible block.
     The inline script above sets the real `open` attribute at this same
     breakpoint, so `details[open] summary` above already provides the
     open-state spacing — nothing to duplicate here. Below 1280px none of
     this applies — the <details> stays exactly as it always was. */
  @media (min-width: 1280px) {
    .toc {
      margin-block: 0;
    }
    /* Nothing left to toggle: the rail is permanently open, and a stray
       click on the summary would otherwise fire the native toggle and
       collapse it again (the resize-driven script above only re-forces
       `open` on a breakpoint CROSSING, not on every click). */
    .toc details summary {
      cursor: default;
      pointer-events: none;
    }
    .toc-chevron { display: none; }
  }
</style>
