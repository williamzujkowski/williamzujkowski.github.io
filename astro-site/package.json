{
  "name": "williamzujkowski-site",
  "type": "module",
  "version": "2.0.0",
  "description": "Personal website of William Zujkowski — Astro 7 + Svelte 5",
  "author": "William Zujkowski",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{astro,svelte,ts,js,css}'",
    "format:check": "prettier --check 'src/**/*.{astro,svelte,ts,js,css}'",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:unit": "node --test '../tests/unit/**/*.test.mjs'",
    "audit:remarque": "node scripts/run-remarque-audit.mjs",
    "audit:typography": "node scripts/typography-audit.mjs",
    "audit:colors": "node scripts/color-token-audit.mjs",
    "audit:accent-font": "node scripts/accent-font-audit.mjs",
    "audit:apca": "node scripts/apca-audit.mjs",
    "audit": "pnpm audit:remarque && pnpm audit:typography && pnpm audit:colors && pnpm audit:accent-font && pnpm audit:apca",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^7.1.0",
    "cookie": "^2.0.1",
    "markdown-it": "^14.3.0",
    "rehype-mermaid": "^3.0.0",
    "remarque-tokens": "^0.5.1",
    "sanitize-html": "^2.17.6",
    "satori": "^0.28.1",
    "svelte": "^5.56.7",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/parser": "^8.65.0",
    "apca-w3": "^0.1.9",
    "colorparsley": "^0.1.8",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^1.6.0",
    "pagefind": "^1.5.2",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.1",
    "remark-smartypants": "^3.0.2"
  },
  "overrides": {
    "fast-xml-parser": ">=5.5.8",
    "fast-xml-builder": ">=1.1.7",
    "uuid": ">=11.1.1",
    "dompurify": ">=3.4.11",
    "vite": ">=8.0.13",
    "esbuild": ">=0.28.1"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.8",
      "fast-xml-builder": ">=1.1.7",
      "uuid": ">=11.1.1",
      "dompurify": ">=3.4.11",
      "vite": ">=8.0.13",
      "esbuild": ">=0.28.1",
      "yaml@<2.8.3": ">=2.8.3",
      "brace-expansion@5": ">=5.0.6"
    }
  }
}
