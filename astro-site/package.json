{
  "name": "williamzujkowski-site",
  "type": "module",
  "version": "2.0.0",
  "description": "Personal website of William Zujkowski — Astro 6 + Svelte 5",
  "author": "William Zujkowski",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{astro,svelte,ts,js,css}'",
    "format:check": "prettier --check 'src/**/*.{astro,svelte,ts,js,css}'",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/svelte": "^8.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "astro": "^6.0.3",
    "markdown-it": "^14.1.1",
    "rehype-mermaid": "^3.0.0",
    "sanitize-html": "^2.17.1",
    "svelte": "^5.53.10",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "pagefind": "^1.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1"
  }
}
