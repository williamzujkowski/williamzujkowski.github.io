# Sample Environment Configuration for Vulnerability Blog Generation
# Copy this file to .env and add your API keys for local development
# For GitHub Actions, configure these values as GitHub Secrets

#########################################
# LLM Provider API Keys (Required)
#########################################

# OpenAI API Key (for GPT-4 and other models)
# Obtain at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Google API Key (for Gemini models)
# Obtain at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key

# Anthropic API Key (for Claude models)
# Obtain at: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=your_claude_api_key

#########################################
# Data Source API Keys (Recommended)
#########################################

# National Vulnerability Database (NVD) API Key
# Obtain at: https://nvd.nist.gov/developers/request-an-api-key
# Higher rate limits with API key (strongly recommended)
NVD_API_KEY=your_nvd_api_key

# AlienVault Open Threat Exchange (OTX) API Key
# Obtain at: https://otx.alienvault.com/api
# Required for threat actor information
ALIENVAULT_OTX_API_KEY=your_alienvault_otx_api_key

#########################################
# User Agent Configuration (Optional)
#########################################

# Custom user agent for VulDB requests
VULDB_USER_AGENT="William Zujkowski Blog Vulnerability Analyzer"

# Custom user agent for CVE.org (primary) and MITRE (legacy) requests
CVE_USER_AGENT="William Zujkowski Blog Vulnerability Analyzer"
MITRE_USER_AGENT="William Zujkowski Blog Vulnerability Analyzer"

#########################################
# LLM Configuration (Optional)
#########################################

# Use smaller, more efficient models to reduce token usage and cost
# Options: true, false
USE_EFFICIENT_MODEL=false

# Enable tiered model approach (cheaper model for data gathering, premium model for synthesis)
# Options: true, false
TIERED_MODEL_APPROACH=true

# Default LLM provider when not specified
# Options: openai, gemini, claude
LLM_PROVIDER=claude

# Specific model selection overrides (optional)
# Uncomment and modify to use specific models
#OPENAI_MODEL=gpt-4-turbo           # Default: gpt-4-turbo
#CLAUDE_MODEL=claude-3-7-sonnet-20240910  # Default: claude-3-7-sonnet-20240910
#GEMINI_MODEL=gemini-2.5-flash      # Default: gemini-2.5-flash

#########################################
# Data Source Feature Toggles (Optional)
#########################################

# Enable MITRE CVE API
# Options: true, false
MITRE_API_ENABLED=true

# Enable Zero Day Initiative (ZDI) data
# Options: true, false
ZDI_ENABLED=true

# Enable CERT Coordination Center (CERT/CC) data
# Options: true, false
CERT_CC_ENABLED=true

# Enable VulDB (Vulnerability Database) data
# Options: true, false
VULDB_ENABLED=true

# Enable SANS Internet Storm Center data
# Options: true, false
SANS_ISC_ENABLED=true

# Enable Exploit-DB data
# Options: true, false
EXPLOIT_DB_ENABLED=true

# Enable CISA Known Exploited Vulnerabilities (KEV) Catalog
# Options: true, false
CISA_KEV_ENABLED=true

# Enable AlienVault OTX integration (requires API key)
# Options: true, false
ALIENVAULT_OTX_ENABLED=true

#########################################
# RAG Configuration (Optional)
#########################################

# Enable Retrieval-Augmented Generation
# Options: true, false
RAG_ENABLED=true

# Maximum number of similar vulnerabilities to include
RAG_MAX_SIMILAR_VULNS=5

# Similarity threshold for including a vulnerability (0.0-1.0)
RAG_SIMILARITY_THRESHOLD=0.75

#########################################
# EPSS Configuration (Optional)
#########################################

# Enable EPSS (Exploit Prediction Scoring System) integration
# Options: true, false
EPSS_ENABLED=true

# Custom user agent for EPSS API requests
EPSS_USER_AGENT="William Zujkowski Blog Vulnerability Analyzer"

#########################################
# General Configuration (Optional)
#########################################

# Minimum CVSS score to consider for vulnerabilities
MIN_CVSS_SCORE=9.0

# Maximum age in days for vulnerabilities to analyze
MAX_VULNERABILITY_AGE_DAYS=30

# Directory for storing cached vulnerability data
CACHE_DIRECTORY=./data

# Output directory for generated blog posts
OUTPUT_DIR=../../src/posts
