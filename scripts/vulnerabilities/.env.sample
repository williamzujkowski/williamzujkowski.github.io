# API KEYS AND CONFIGURATION
# Copy this file to .env and fill in your actual values

#=======================================================================
# LANGUAGE MODEL PROVIDER CONFIGURATION
#=======================================================================
# Set which LLM provider to use - options: "openai", "gemini", or "claude"
LLM_PROVIDER=gemini

# OpenAI API key (only needed if using OpenAI)
# OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API key (needed if using Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API key (only needed if using Claude)
# CLAUDE_API_KEY=your_claude_api_key_here

#=======================================================================
# VULNERABILITY DATA SOURCES
#=======================================================================

# National Vulnerability Database (NVD) API Key
# Highly recommended - provides higher rate limits for NVD API
# Register at: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=your_nvd_api_key_here

# MITRE CVE API
# For direct access to the authoritative CVE data
# No API key required, but recommended to set a user agent
# API docs: https://cveawg.mitre.org/api-docs/
MITRE_API_ENABLED=true
MITRE_USER_AGENT=WilliamZujkowskiBlogVulnerabilityAnalyzer

# CISA Known Exploited Vulnerabilities (KEV) Catalog
# No API key required
# Direct JSON feed: https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
CISA_KEV_ENABLED=true

# GitHub API Token
# For accessing repository data, POCs, discussions on vulnerabilities
# Create at: https://github.com/settings/tokens
# Recommended scopes: public_repo, read:packages
# GITHUB_API_TOKEN=your_github_token_here

# Exploit Database (Exploit-DB)
# For finding public exploits
# No API key required for basic searching via their CSV feed
# EXPLOIT_DB_ENABLED=true

# Snyk Vulnerability Database
# For open source package vulnerabilities
# Register at: https://app.snyk.io/login
# SNYK_API_TOKEN=your_snyk_api_token_here

# Red Hat Security Data API
# For Linux/enterprise vulnerabilities
# No API key required
# RED_HAT_SECURITY_API_ENABLED=true

# SANS Internet Storm Center
# For current threats and security community insights
# No API key required
# RSS feed: https://isc.sans.edu/rssfeed_full.xml
SANS_ISC_ENABLED=true

#=======================================================================
# THREAT INTELLIGENCE SOURCES
#=======================================================================

# VirusTotal API Key
# For malware intelligence and exploit detection
# Register at: https://developers.virustotal.com/reference
# VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AlienVault OTX API Key
# For threat actor information and campaign data
# Register at: https://otx.alienvault.com/api
# Documentation: https://otx.alienvault.com/api/
# ALIENVAULT_OTX_API_KEY=your_otx_api_key_here
# ALIENVAULT_OTX_ENABLED=true

# Shodan API Key
# For discovering internet-exposed vulnerable systems
# Register at: https://account.shodan.io/register
# SHODAN_API_KEY=your_shodan_api_key_here

# MISP API Key
# For access to community threat intelligence
# Requires access to a MISP instance
# MISP_API_KEY=your_misp_api_key_here
# MISP_URL=https://your-misp-instance.example.com

#=======================================================================
# CLOUD SECURITY SOURCES
#=======================================================================

# AWS Security Hub API
# For AWS-specific vulnerability data
# Use standard AWS credential configuration
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# Google Security Command Center
# For Google Cloud vulnerability data
# Use Google Cloud service account key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-file.json

#=======================================================================
# SYSTEM CONFIGURATION
#=======================================================================

# Cache directory for storing vulnerability data
CACHE_DIRECTORY=./.cache

# Maximum vulnerability age in days (for --latest option)
MAX_VULNERABILITY_AGE_DAYS=30

# Minimum CVSS score to consider (0.0-10.0)
MIN_CVSS_SCORE=7.5
