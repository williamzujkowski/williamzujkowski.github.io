# API keys and configuration
# Copy this file to .env and fill in your actual values

# Model selection - set to "openai", "gemini", or "claude"
LLM_PROVIDER=openai

# OpenAI API key for generating blog content (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API key (if using Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API key (if using Claude)
CLAUDE_API_KEY=your_claude_api_key_here

# Optional: API keys for additional vulnerability data sources
# NVD_API_KEY=your_nvd_api_key_here
# THREATFOX_API_KEY=your_threatfox_api_key_here
