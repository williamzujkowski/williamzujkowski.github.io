{
  "name": "williamzujkowski-website",
  "version": "1.0.0",
  "description": "William Zujkowski's personal website",
  "main": "index.js",
  "type": "module",
  "homepage": "https://williamzujkowski.github.io",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "build": "npm run build:data && npm run dashboard:ensure && eleventy --config=.eleventy.cjs && npm run build:css && npm run build:js",
    "build:css": "postcss src/css/main.css -o _site/css/styles.css --config=config/postcss.config.cjs",
    "build:data": "node scripts/build/create-core-data.js",
    "build:link-previews": "node scripts/content/link-preview-generator.js",
    "build:js": "rollup -c rollup.config.js",
    "build:js:prod": "NODE_ENV=production rollup -c rollup.config.js",
    "watch:css": "postcss src/css/main.css -o _site/css/styles.css --watch --config=config/postcss.config.cjs",
    "watch:js": "rollup -c rollup.config.js --watch",
    "serve": "npm run build:data && concurrently \"eleventy --config=.eleventy.cjs --serve\" \"npm run watch:css\" \"npm run watch:js\"",
    "dev": "npm run serve",
    "debug": "DEBUG=* eleventy --config=.eleventy.cjs",
    "process:posts": "node scripts/content/posts/process-new-posts.js",
    "process:posts:enhanced": "node scripts/content/posts/enhance-post-processor.js",
    "optimize:images": "node scripts/media/images/optimize-images.js",
    "optimize:images:blog": "chmod +x scripts/bin/media.sh && scripts/bin/media.sh optimize-blog",
    "optimize:data": "node scripts/data/optimize-data-management.js",
    "optimize:js": "npm run build:js:prod",
    "analyze:js": "ANALYZE=true rollup -c rollup.config.js",
    "build:optimized": "node scripts/build/optimized-build.js build",
    "build:optimized:debug": "node scripts/build/optimized-build.js build --debug",
    "build:optimized:force": "node scripts/build/optimized-build.js build --force",
    "serve:optimized": "node scripts/build/optimized-build.js serve",
    "dev:optimized": "npm run serve:optimized",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.{js,json,css,md,njk}\"",
    "build:prod": "NODE_ENV=production npm run build:optimized && npm run build:js:prod",
    "analyze": "lighthouse https://williamzujkowski.github.io/ --output=json --output-path=./lighthouse-report.json --view",
    "analyze:performance": "npm run analyze:js && npm run analyze",
    "test": "node scripts/testing/run-tests.js",
    "test:templates": "node scripts/testing/verify-templates.js",
    "test:build": "node scripts/testing/verify-build.js",
    "test:components": "node scripts/testing/run-component-tests.js",
    "test:unit": "node scripts/testing/run-component-tests.js unit",
    "test:integration": "node scripts/testing/run-component-tests.js integration",
    "test:security": "node scripts/testing/run-component-tests.js security",
    "test:performance": "node scripts/testing/run-component-tests.js performance",
    "test:accessibility": "node scripts/testing/run-accessibility-tests.js",
    "test:coverage": "node scripts/testing/generate-coverage-report.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:visual": "playwright test --config=tests/visual/playwright.config.js",
    "test:visual:update": "playwright test --config=tests/visual/playwright.config.js --update-snapshots",
    "test:all": "npm run test && npm run test:components && npm run test:e2e",
    "test:ci": "npm run test:all",
    "verify:build": "node scripts/build/verify-build-config.js",
    "standardize:frontmatter": "node scripts/standardize-frontmatter.js",
    "convert:images": "node scripts/convert-image-tags.js",
    "build:ci": "npm run build:data && eleventy --config=.eleventy.simple.cjs",
    "create:wrapper": "mkdir -p scripts/wrapper && touch scripts/wrapper/generate-vuln-post-wrapper.js && chmod +x scripts/wrapper/generate-vuln-post-wrapper.js",
    "generate:vuln": "npm run create:wrapper && node scripts/wrapper/generate-vuln-post-wrapper.js --",
    "generate:latest": "npm run create:wrapper && node scripts/wrapper/generate-vuln-post-wrapper.js --latest",
    "schedule:vuln": "cd tools/vuln-blog && node schedule-posts.js --output-dir ../../src/posts/",
    "test:openai": "cd tools/vuln-blog && node test-models.js --provider openai",
    "test:gemini": "cd tools/vuln-blog && node test-models.js --provider gemini",
    "test:claude": "cd tools/vuln-blog && node test-models.js --provider claude",
    "test:llm": "cd tools/vuln-blog && node test-models.js --provider all",
    "test:sources": "cd tools/vuln-blog && node test-data-sources.js",
    "dashboard:update": "cd tools/vuln-blog && node --experimental-modules src/scripts/update-dashboard-data.js",
    "dashboard:ensure": "node scripts/dashboard/ensure-dashboard-data.js",
    "build:dashboard": "npm run dashboard:update && npm run dashboard:ensure",
    "build:with-dashboard": "npm run build:dashboard && npm run build",
    "generate:blog": "npm run create:blog-wrapper && node scripts/wrapper/generate-blog-post-wrapper.js --",
    "create:blog-wrapper": "mkdir -p scripts/wrapper && touch scripts/wrapper/generate-blog-post-wrapper.js && chmod +x scripts/wrapper/generate-blog-post-wrapper.js",
    "scripts:verify": "node scripts/verify-scripts.js",
    "scripts:docs": "node scripts/add-jsdoc.js"
  },
  "keywords": [],
  "author": "William Zujkowski",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.1",
    "@11ty/eleventy-navigation": "^0.3.5",
    "@11ty/eleventy-plugin-rss": "^2.0.3",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@axe-core/puppeteer": "^4.8.5",
    "@browserless/goto": "^10.7.3",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.17",
    "chalk": "^5.3.0",
    "concurrently": "^8.2.2",
    "cssnano": "^6.0.4",
    "eslint": "^9.24.0",
    "glob": "^11.0.1",
    "got": "^14.4.7",
    "gray-matter": "^4.0.3",
    "jsdom": "^24.0.0",
    "lighthouse": "^12.5.1",
    "luxon": "^3.4.4",
    "lru-cache": "^10.2.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "metascraper": "^5.46.11",
    "metascraper-author": "^5.46.11",
    "metascraper-date": "^5.46.11",
    "metascraper-description": "^5.46.11",
    "metascraper-image": "^5.46.11",
    "metascraper-logo": "^5.46.11",
    "metascraper-publisher": "^5.46.11",
    "metascraper-title": "^5.46.11",
    "metascraper-url": "^5.46.11",
    "node-fetch": "^3.3.2",
    "nyc": "^15.1.0",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.42.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.5.3",
    "puppeteer": "^24.6.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.40.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "sharp": "^0.33.4",
    "slugify": "^1.6.6",
    "tailwindcss": "^3.4.1",
    "terser": "^5.30.0",
    "xml2js": "^0.6.2"
  }
}
