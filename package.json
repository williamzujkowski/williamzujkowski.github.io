{
  "name": "williamzujkowski-website",
  "version": "1.0.0",
  "description": "William Zujkowski's personal website",
  "main": "index.js",
  "type": "module",
  "homepage": "https://williamzujkowski.github.io",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "build": "npm run build:data && eleventy --config=config/.eleventy.simple.cjs && npm run build:css",
    "build:css": "postcss src/css/styles.css -o _site/css/styles.css --config=config/postcss.config.cjs",
    "build:data": "node scripts/create-fallback-data.js && npm run build:arxiv && npm run build:github && npm run build:viz && npm run build:books && (npm run build:links || true)",
    "build:arxiv": "node scripts/build-arxiv-feed.js",
    "build:github": "node scripts/build-github-pins.js",
    "build:viz": "node scripts/build-visualizations.js",
    "build:books": "node scripts/build-book-data.js",
    "build:links": "node scripts/build-link-previews.js",
    "validate:links": "node tools/validation/validate-links.js",
    "validate:config": "node tools/validation/validate-config.js",
    "validate:all": "npm run validate:links && npm run validate:config",
    "fix:config": "node tools/validation/validate-config.js --fix",
    "extract:components": "node tools/extract-components.js",
    "extract:components:dry": "node tools/extract-components.js --dry-run",
    "process:links:initial": "node scripts/build-link-previews.js --initial",
    "process:posts": "node tools/process-new-posts.js",
    "generate:theme": "node tools/generate-theme.js",
    "watch:css": "postcss src/css/styles.css -o _site/css/styles.css --watch --config=config/postcss.config.cjs",
    "serve": "npm run build:data && npm run watch:css & eleventy --config=config/.eleventy.simple.cjs --serve",
    "dev": "npm run serve",
    "debug": "DEBUG=* eleventy --config=config/.eleventy.simple.cjs",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.{js,json,css,md,njk}\"",
    "build:prod": "NODE_ENV=production npm run build",
    "optimize": "npm run optimize:css && npm run optimize:js && npm run optimize:images",
    "optimize:css": "NODE_ENV=production npm run build:css",
    "optimize:js": "terser src/js/*.js -o _site/js/bundle.min.js --compress --mangle",
    "optimize:images": "npm install sharp && node scripts/optimize-images.js",
    "analyze": "lighthouse https://williamzujkowski.github.io/ --output=json --output-path=./lighthouse-report.json --view"
  },
  "keywords": [],
  "author": "William Zujkowski",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.1",
    "@11ty/eleventy-navigation": "^0.3.5",
    "@11ty/eleventy-plugin-rss": "^2.0.3",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@browserless/goto": "^10.7.3",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.17",
    "cssnano": "^6.0.4",
    "eslint": "^9.24.0",
    "got": "^14.4.7",
    "gray-matter": "^4.0.3",
    "lighthouse": "^11.6.0",
    "luxon": "^3.4.4",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "metascraper": "^5.46.11",
    "metascraper-author": "^5.46.11",
    "metascraper-date": "^5.46.11",
    "metascraper-description": "^5.46.11",
    "metascraper-image": "^5.46.11",
    "metascraper-logo": "^5.46.11",
    "metascraper-publisher": "^5.46.11",
    "metascraper-title": "^5.46.11",
    "metascraper-url": "^5.46.11",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.5.3",
    "puppeteer": "^24.6.0",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.1",
    "terser": "^5.30.0",
    "xml2js": "^0.6.2"
  },
  "dependencies": {
    "@microlink/vanilla": "^5.5.23"
  }
}
