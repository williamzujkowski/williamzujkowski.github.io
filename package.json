{
  "name": "williamzujkowski-website",
  "version": "1.0.0",
  "description": "William Zujkowski's personal website",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run build:arxiv && npm run build:github && eleventy --config=.eleventy.cjs",
    "build:css": "postcss src/css/styles.css -o _site/css/styles.css",
    "build:arxiv": "node build-arxiv-feed.js",
    "build:github": "node build-github-pins.js",
    "watch:css": "postcss src/css/styles.css -o _site/css/styles.css --watch",
    "serve": "npm run watch:css & eleventy --config=.eleventy.cjs --serve",
    "dev": "npm run serve",
    "debug": "DEBUG=* eleventy --config=.eleventy.cjs"
  },
  "keywords": [],
  "author": "William Zujkowski",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@11ty/eleventy-navigation": "^0.3.5",
    "@11ty/eleventy-plugin-rss": "^1.2.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "autoprefixer": "^10.4.17",
    "cssnano": "^6.0.4",
    "luxon": "^3.4.4",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "^8.6.7",
    "node-fetch": "^3.3.2",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.1",
    "xml2js": "^0.6.2"
  }
}
