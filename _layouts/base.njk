<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  {% include "meta.njk" %}
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <header class="gh-header">
    <div class="gh-header-inner">
      <div class="gh-nav">
        {%- set navPages = collections.all | eleventyNavigation -%}
        {%- for entry in navPages %}
          <a href="{{ entry.url | url }}" class="gh-nav-item {% if page.url == entry.url %}active{% endif %}">
            <span>{{ entry.title }}</span>
          </a>
        {%- endfor %}
      </div>
      
      <div class="gh-nav">
        {% for social in site.social_media %}
          {% if social.enabled and social.display_in_header %}
            <a href="{{ social.url }}" class="gh-nav-item" aria-label="{{ social.name }}">
              {{ social.icon | safe }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </header>

  <div class="site-container">
    <main id="main-content">
      {{ content | safe }}
    </main>

    <footer class="gh-footer">
      <div class="gh-footer-inner">
        <div class="gh-footer-links">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="/links/">Links</a>
          <a href="/contact/">Contact</a>
          <a href="/feed.xml">RSS</a>
        </div>
        <div class="gh-copyright">
          &copy; {% year %} {{ site.author }} | Built with <a href="https://www.11ty.dev/">11ty</a>
        </div>
      </div>
    </footer>
  </div>

  <!-- Back to top button -->
  <button id="back-to-top" class="back-to-top-btn" aria-label="Back to top">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
      <path d="M8.53 4.22a.75.75 0 00-1.06 0l-4.25 4.25a.75.75 0 001.06 1.06L8 5.81l3.72 3.72a.75.75 0 101.06-1.06L8.53 4.22z"></path>
    </svg>
  </button>

  <script src="/js/main.js"></script>
  <script src="/js/heatmap.js"></script>
  <script src="/js/site-enhancements.js"></script>
  <script src="/js/search.js"></script>
</body>
</html>