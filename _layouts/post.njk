---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <time class="post-date">
      {% if page.date %}
        {{ page.date | readableDate }}
      {% else %}
        Unknown Date
      {% endif %}
    </time>
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <a href="/blog/" class="back-link">&larr; Back to all posts</a>
  </footer>
</article>