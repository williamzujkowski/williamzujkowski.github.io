---
layout: base.njk
---
<div class="max-w-2xl mx-auto">
  <div class="mb-4">
    <a href="/blog/" class="inline-flex items-center text-sm text-accent hover:underline">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="mr-1">
        <path d="M7.78 12.53a.75.75 0 01-1.06 0L2.47 8.28a.75.75 0 010-1.06l4.25-4.25a.75.75 0 011.06 1.06L4.81 7h7.44a.75.75 0 010 1.5H4.81l2.97 2.97a.75.75 0 010 1.06z"></path>
      </svg>
      Back to all posts
    </a>
  </div>

  <article class="border border-border rounded-github overflow-hidden">
    <div class="p-4 border-b border-border bg-surface">
      <h1 class="text-2xl font-semibold mt-0 mb-2">{{ title }}</h1>
      
      <div class="flex items-center gap-2 text-text-secondary mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
          <path d="M4.75 0a.75.75 0 01.75.75V2h5V.75a.75.75 0 011.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0113.25 16H2.75A1.75 1.75 0 011 14.25V3.75C1 2.784 1.784 2 2.75 2H4V.75A.75.75 0 014.75 0zm0 3.5h8.5a.25.25 0 01.25.25V6h-9V3.75a.25.25 0 01.25-.25zm-2 3h10.5v7.75a.25.25 0 01-.25.25H2.75a.25.25 0 01-.25-.25V6.5z"></path>
        </svg>
        <time datetime="{{ page.date | isoDate }}">
          {% if page.date %}
            {{ page.date | readableDate }}
          {% else %}
            Unknown Date
          {% endif %}
        </time>
      </div>
      
      {% if tags %}
        <div class="flex flex-wrap gap-1">
          {% for tag in tags %}
            {% if tag != "posts" %}
              <span class="gh-badge gh-badge-accent">{{ tag }}</span>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="p-6 bg-surface">
      <div class="mb-6">
        <img src="/assets/images/github-style/blog-placeholder.svg" alt="Blog post illustration" class="w-full rounded-github">
      </div>
      <div class="prose max-w-none">
        {{ content | safe }}
      </div>
    </div>
  </article>
  
  <div class="mt-8 flex justify-between">
    <a href="/blog/" class="gh-btn flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="mr-2">
        <path d="M7.78 12.53a.75.75 0 01-1.06 0L2.47 8.28a.75.75 0 010-1.06l4.25-4.25a.75.75 0 011.06 1.06L4.81 7h7.44a.75.75 0 010 1.5H4.81l2.97 2.97a.75.75 0 010 1.06z"></path>
      </svg>
      Back to all posts
    </a>
    
    <div class="flex items-center gap-2">
      <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.url }}{{ page.url | urlencode }}" 
        target="_blank" rel="noopener noreferrer" class="gh-btn" aria-label="Share on Twitter">
        Share
      </a>
    </div>
  </div>
</div>